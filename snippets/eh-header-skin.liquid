{% comment %} Muybieno — global header/menu skin (kahve/krem) {% endcomment %}
{%- style -%}
  .header-wrapper {
    --eh-primary: #5C3A1E;
    --eh-primary-tint: rgba(92, 58, 30, 0.10);
    --eh-secondary: #8A5A2E;
    --eh-on-surface: #3A2818;
    --font-head: "Bricolage Grotesque", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
  }

  /* Sticky header'ı sayfa içeriğinin kesinlikle üstünde tut. Dawn varsayılanı
     z-index:3; kart quick-add gibi z-index:3 içerik denk gelip menünün üstüne
     çıkabiliyordu. Sepet bildirimi (z-index:100) hâlâ header'ın önünde kalır. */
  .section-header.shopify-section-group-header-group { z-index: 10; }

  /* Metinli logo (görsel + marka adı + alt başlık) */
  .header-wrapper .header__heading-link {
    display: inline-flex;
    align-items: center;
    gap: 1.2rem;
    font-family: var(--font-head);
    white-space: nowrap;
  }
  .header-wrapper .header__heading { max-width: none; }
  .eh-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-align: left;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .eh-brand-name {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 2rem;
    letter-spacing: -0.01em;
    color: var(--eh-primary);
    white-space: nowrap;
  }
  .eh-brand-sub {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    color: var(--eh-secondary);
    margin-top: 0.35rem;
  }
  @media screen and (max-width: 989px) {
    .eh-brand-text { display: none; }
  }

  /* Muybieno wordmark (settings.logo boşken tema varlığından) */
  .header-wrapper .eh-wordmark {
    display: block;
    height: 6rem;
    width: auto;
    object-fit: contain;
  }
  @media screen and (max-width: 749px) {
    .header-wrapper .eh-wordmark { height: 4.6rem; }
  }


  /* Masaüstü menü linkleri — yeşil pill hover, alt çizgi yok */
  .header-wrapper .header__inline-menu .header__menu-item {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.5rem;
    color: var(--eh-on-surface);
    border-radius: 0.6rem;
    padding: 0.8rem 1.1rem;
    text-decoration: none;
    transition: background .15s ease, color .15s ease;
  }
  /* Caret'i yazının yanına inline al, sağdaki fazla boşluğu kaldır */
  .header-wrapper .header__inline-menu summary.header__menu-item {
    padding-right: 1.1rem;
  }
  .header-wrapper .header__inline-menu .header__menu-item .icon-caret {
    position: static;
    right: auto;
    margin-left: 0.5rem;
  }
  /* Tıklanabilir üst menü başlığı (koleksiyona gider) */
  .header-wrapper .header__menu-parent-link {
    color: inherit;
    text-decoration: none !important;
    cursor: pointer;
  }
  .header-wrapper .header__inline-menu .header__menu-item:hover {
    background: var(--eh-primary-tint);
    color: var(--eh-primary);
  }
  /* Hover/aktif alt çizgiyi kaldır */
  .header-wrapper .header__menu-item,
  .header-wrapper .header__menu-item:hover,
  .header-wrapper .header__menu-item:focus,
  .header-wrapper .header__submenu .header__menu-item:hover,
  .header-wrapper .header__active-menu-item {
    text-decoration: none !important;
  }
  .header-wrapper .header__menu-item:hover .header__active-menu-item {
    text-decoration: none !important;
  }
  /* Aktif menü öğesi */
  .header-wrapper .header__inline-menu .header__menu-item.list-menu__item--active,
  .header-wrapper .header__active-menu-item {
    color: var(--eh-primary);
    font-weight: 600;
  }
  /* Sense'in alt-çizgi animasyonunu yeşile çek */
  .header-wrapper .header__menu-item span,
  .header-wrapper .header__active-menu-item {
    text-underline-offset: 0.3rem;
  }
  .header-wrapper .header__menu-item:hover .header__active-menu-item {
    color: var(--eh-primary);
  }

  /* Açılır (dropdown) menü */
  .header-wrapper .header__submenu {
    border-radius: 0 0 1rem 1rem;
    box-shadow: 0 12px 30px rgba(92, 58, 30, 0.12);
    border: none;
  }
  .header-wrapper .header__submenu .header__menu-item {
    border-radius: 0.5rem;
    transition: background .15s ease, color .15s ease;
  }
  .header-wrapper .header__submenu .header__menu-item:hover {
    background: var(--eh-primary-tint);
    color: var(--eh-primary);
  }

  /* ============ kahve.com tarzı header: logo + uzun arama üstte, kategoriler altta ============ */
  .header-wrapper .eh-search { display: none; position: relative; }
  /* arama çubuğu görünümü (masaüstü) */
  .header-wrapper .eh-search__form .field { position: relative; display: flex; align-items: center; margin: 0; }
  /* Dawn native .field::before/::after çerçeve halkasını (radius 10px köşeli
     dikdörtgen, box-shadow ile çizili) sustur — bizim pill input border'ımızla
     iç içe geçmiş çift çerçeve yaratıyordu. Tek çerçeve input'ta kalsın. */
  .header-wrapper .eh-search__form .field::before,
  .header-wrapper .eh-search__form .field::after {
    box-shadow: none; border: none; background: transparent;
  }
  .header-wrapper .eh-search__form .search__input {
    width: 100%; height: 4.6rem; border-radius: 999px;
    border: 1px solid rgba(92,58,30,0.18); background: #FFFCF7;
    padding: 0 4.6rem 0 1.8rem; margin: 0;
    font-family: "Inter", system-ui, sans-serif; font-size: 1.4rem; color: #2A1B0E;
  }
  .header-wrapper .eh-search__form .search__input::placeholder { color: #9C8773; }
  .header-wrapper .eh-search__form .search__input:focus {
    border-color: #8A5A2E; outline: none; box-shadow: 0 0 0 3px rgba(138,90,46,0.12);
  }
  .header-wrapper .eh-search__form .field__label { display: none; }
  .header-wrapper .eh-search__form .search__button {
    position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);
    width: 3.8rem; height: 3.8rem; border-radius: 50%; display: grid; place-items: center;
    color: #5C3A1E; background: none; border: none; cursor: pointer;
  }
  .header-wrapper .eh-search__form .search__button .svg-wrapper svg { width: 2rem; height: 2rem; }
  .header-wrapper .eh-search__form .reset__button { position: absolute; right: 4.4rem; top: 50%; transform: translateY(-50%); }
  .header-wrapper .eh-search .predictive-search {
    position: absolute; top: calc(100% + 0.6rem); left: 0; right: 0; z-index: 6;
    border-radius: 1.2rem; overflow: hidden;
  }

  @media screen and (min-width: 990px) {
    /* 2 satırlı grid: 1. satır logo|arama|ikonlar, 2. satır kategoriler tam genişlik */
    .header-wrapper .header {
      grid-template-areas:
        'heading search icons'
        'nav nav nav' !important;
      grid-template-columns: auto minmax(30rem, 1fr) auto !important;
      column-gap: 2.4rem;
      row-gap: 1.4rem;
      align-items: center;
    }
    .header-wrapper .header__heading,
    .header-wrapper .header > .header__heading-link { grid-area: heading; margin: 0; justify-self: start; }
    .header-wrapper .eh-search { grid-area: search; display: block; width: 100%; max-width: 38rem; justify-self: center; }
    .header-wrapper .header__icons { grid-area: icons; }
    .header-wrapper .header__inline-menu { grid-area: nav; margin: 0; width: 100%; }
    /* inline arama varken modal arama ikonunu gizle */
    .header-wrapper .header__search,
    .header-wrapper .header__icons .header__icon--search,
    .header-wrapper .header__icons details-modal.header__search { display: none !important; }
  }

  /* ---- Üst seviye MEGA menü: TAM GENİŞLİK (header'a sabit, page-width) ---- */
  .header-wrapper .eh-mega__media { display: none; }
  @media screen and (min-width: 990px) {
    /* Paneli header genişliğinde açmak için: details'in relative'ini kaldır → anchor = .header */
    .header-wrapper .header { position: relative; }
    .header-wrapper .header__inline-menu > .list-menu > li > header-menu > details { position: static; }
    .header-wrapper .header__inline-menu .eh-mega .eh-mega__media { display: block; }

    .header-wrapper .header__inline-menu .eh-mega {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 0.8rem);
      width: auto;
      min-width: 0;
      max-width: none;
      box-sizing: border-box;
      margin: 0;
      padding: 2.8rem 3.6rem;
      border-radius: 1.4rem;
      z-index: 5;
      display: grid;
      grid-auto-flow: column;
      grid-template-rows: repeat(2, auto);
      grid-template-columns: repeat(3, max-content) 1fr;
      column-gap: 3.2rem;
      row-gap: 0.2rem;
      align-content: start;
    }
    .header-wrapper .header__inline-menu .eh-mega.eh-mega--has-media {
      grid-template-columns: repeat(3, max-content) 1fr minmax(26rem, 34rem);
    }
    .header-wrapper .header__inline-menu .eh-mega > li { width: 100%; }
    .header-wrapper .header__inline-menu .eh-mega > li .header__menu-item {
      font-size: 1.5rem;
      font-weight: 600;
      padding: 1.15rem 1.2rem;
      white-space: nowrap;
    }
    /* Sağdaki görsel — son sütun, tüm satırları kaplar */
    .header-wrapper .header__inline-menu .eh-mega .eh-mega__media {
      grid-column: -2 / -1;
      grid-row: 1 / -1;
      align-self: stretch;
      margin: 0;
      padding: 0;
    }
    .header-wrapper .header__inline-menu .eh-mega .eh-mega__media img {
      width: 100%;
      height: 100%;
      min-height: 20rem;
      max-height: 28rem;
      object-fit: cover;
      border-radius: 1.2rem;
      display: block;
    }
  }

  /* ---- Nav tek satır: taşma/alt satıra kayma engeli ---- */
  @media screen and (min-width: 990px) {
    .header-wrapper .header__inline-menu .list-menu--inline {
      flex-wrap: nowrap;
      white-space: nowrap;
      width: 100%;
      justify-content: space-between;
      column-gap: 1.2rem;
    }
    .header-wrapper .header__inline-menu .list-menu--inline > li > .header__menu-item,
    .header-wrapper .header__inline-menu .list-menu--inline > li > header-menu > details > .header__menu-item {
      padding-left: 1.1rem;
      padding-right: 1.1rem;
    }
  }
  @media screen and (min-width: 990px) and (max-width: 1200px) {
    .header-wrapper .header__inline-menu .list-menu--inline > li .header__menu-item { font-size: 1.4rem; }
    .header-wrapper .header__inline-menu .list-menu--inline > li > .header__menu-item,
    .header-wrapper .header__inline-menu .list-menu--inline > li > header-menu > details > .header__menu-item {
      padding-left: 0.7rem;
      padding-right: 0.7rem;
    }
  }

  /* İkonlar — yuvarlak yeşil hover */
  .header-wrapper .header__icons .header__icon {
    border-radius: 50%;
    transition: background .15s ease, color .15s ease;
  }
  .header-wrapper .header__icons .header__icon:hover {
    background: var(--eh-primary-tint);
    color: var(--eh-primary);
  }

  /* Sepet sayacı — umber */
  .header-wrapper .cart-count-bubble {
    background-color: var(--eh-secondary) !important;
  }

  /* ---- Sepete ekleme bildirimi (cart notification) ---- */
  .cart-notification { border-radius: 1.2rem; }
  .cart-notification__heading,
  .cart-notification-product__name {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
  }
  .cart-notification-product__name { color: #5C3A1E; font-weight: 600; }
  .cart-notification__heading .icon-checkmark,
  .cart-notification svg.icon-checkmark { color: #5C3A1E; }

  /* Ödeme — yeşil primary */
  .cart-notification .button--primary {
    background: #5C3A1E !important;
    color: #fff !important;
    border: 1.5px solid #5C3A1E !important;
    border-radius: 0.5rem;
  }
  .cart-notification .button--primary:hover { background: #4A2C17 !important; }
  .cart-notification .button--primary::after,
  .cart-notification .button--secondary::after { display: none !important; }

  /* Sepeti görüntüle — yeşil çizgili */
  .cart-notification .button--secondary {
    background: #fff !important;
    color: #5C3A1E !important;
    border: 1.5px solid #5C3A1E !important;
    border-radius: 0.5rem;
  }
  .cart-notification .button--secondary:hover { background: rgba(92, 58, 30, 0.06) !important; }

  /* Alışverişe devam et — temiz link */
  .cart-notification__links .link,
  .cart-notification .cart-notification__continue {
    color: #5C3A1E;
    text-decoration: none;
  }
  .cart-notification__links .link:hover { text-decoration: underline; }

  /* ---- Mobil menü (drawer) — Earth & Harvest ---- */
  .menu-drawer {
    font-family: "Inter", system-ui, sans-serif;
    background: #fbf9f8;
    padding: 1rem 2.4rem 2.4rem;
  }
  .menu-drawer__navigation { padding: 0; }
  /* Ana menü öğeleri */
  .menu-drawer__menu-item {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.7rem;
    letter-spacing: -0.01em;
    color: #2A1B0E;
    padding: 1.5rem 0.4rem;
    text-decoration: none !important;
    transition: color .15s ease, background .15s ease;
    border-radius: 0.6rem;
  }
  .menu-drawer__menu-item:hover { color: #5C3A1E; background: rgba(92, 58, 30, 0.06); }
  .menu-drawer__parent-link { color: inherit; text-decoration: none !important; }
  .menu-drawer__menu-item--active { color: #5C3A1E; }
  .menu-drawer summary.menu-drawer__menu-item { padding-right: 1rem; }
  /* Öğeler arası ayraç */
  .menu-drawer__navigation > .menu-drawer__menu > li {
    border-bottom: 1px solid rgba(92, 58, 30, 0.10);
  }
  .menu-drawer__navigation > .menu-drawer__menu > li:last-child { border-bottom: none; }
  /* Açılır ok */
  .menu-drawer__menu-item .icon-caret,
  .menu-drawer__menu-item .svg-wrapper { color: #8A5A2E; }

  /* Alt menü */
  .menu-drawer__submenu { background: #fbf9f8; }
  .menu-drawer__close-button {
    font-family: "Bricolage Grotesque", system-ui, sans-serif;
    font-weight: 600;
    color: #5C3A1E;
    text-decoration: none !important;
  }
  .menu-drawer__close-button .icon-arrow { color: #5C3A1E; }

  /* Alt yardımcı linkler (hesap, dil vb.) */
  .menu-drawer__utility-links {
    background: #fff;
    border-top: 1px solid rgba(92, 58, 30, 0.10);
  }
  .menu-drawer__account {
    font-family: "Inter", system-ui, sans-serif;
    color: #5C3A1E;
    font-weight: 600;
  }
  .menu-drawer__account .icon-account { color: #5C3A1E; }

  /* Hamburger / kapat ikonu */
  .header__icon--menu .icon { color: #2A1B0E; }
  .header__icon--menu:hover .icon { color: #5C3A1E; }

  /* ---- Topbar / duyuru çubuğu — espresso gradyan bant ---- */
  .utility-bar {
    background: linear-gradient(135deg, #5C3A1E 0%, #8A5A2E 55%, #B07A45 100%) !important;
    background-image: linear-gradient(135deg, #5C3A1E 0%, #8A5A2E 55%, #B07A45 100%) !important;
    color: #FBF3E7 !important;
  }
  .utility-bar--bottom-border { border-bottom-color: rgba(255, 255, 255, 0.15) !important; }
  .utility-bar .announcement-bar__message,
  .utility-bar .announcement-bar__link,
  .utility-bar .announcement-bar__link .icon,
  .utility-bar a,
  .utility-bar .localization-selector,
  .utility-bar .slider-button .icon { color: #fff !important; }
  .utility-bar .announcement-bar__message {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 500;
    font-size: 1.3rem;
    letter-spacing: 0.02em;
    text-transform: none;
  }
  .utility-bar .announcement-bar__link:hover { text-decoration: underline; }
{%- endstyle -%}
