{% comment %}
  Muybieno — ürün alt içerik: her ekranda (masaüstü + mobil) yatay sekme.
  Şerit "segmented control": camsı krem kapsül içinde eşit genişlikte büyük
  butonlar; aktif sekme espresso CTA gradyanı (Sepete ekle ile aynı token).
  Taşarsa şerit yatay kayar (scrollbar gizli).
  Paneller (içeriği olan render edilir):
    d  Ürün açıklaması     → product.description
    t  Tadım notları       → custom.tat_profili
    b  Demleme önerisi     → custom.demleme_onerisi (+ custom.ogutum_onerisi satırı)
    k  Teslimat      → block.settings.kargo_content
    r  Yorumlar            → Judge.me widget (reviews_judgeme, varsayılan açık) veya
                             block.settings.reviews_liquid gömme kodu (doluysa o kazanır).
                             İkisi de yoksa sekme gizli.
  Judge.me v3 notu: widget, şablondaki "apps" section'ında duran resmi
  "Review Widget" app block'undan gelir (v3 içerik metafield'dan DEĞİL,
  data-entry-point attribute'lu div'i client-side render ederek gelir).
  Bu snippet'in JS'i o bloğu DOMContentLoaded'da Yorumlar paneline taşır;
  blok şablonda yoksa Yorumlar sekmesi JS ile gizlenir. Ayrıca "Judge.me"
  app embed'i temada aktif olmalı (loader script'i o yükler).
{% endcomment %}
{%- liquid
  assign mf = product.metafields.custom
  assign desc = product.description
  assign tat = mf.tat_profili
  assign dem = mf.demleme_onerisi
  assign ogutum = mf.ogutum_onerisi
  assign kargo = block.settings.kargo_content
  assign reviews = block.settings.reviews_liquid
  assign show_reviews = false
  if reviews != blank or block.settings.reviews_judgeme
    assign show_reviews = true
  endif
  assign any = false
  if desc != blank or tat != blank or dem != blank or ogutum != blank or kargo != blank or show_reviews
    assign any = true
  endif
-%}

{%- if any -%}
  <div class="eh-tabs" id="EhTabs-{{ section.id }}" {{ block.shopify_attributes }}>
    <div class="eh-tabs__strip" role="tablist">
      {%- if tat != blank -%}<button type="button" class="eh-tabs__tab" data-eh-tab="t" role="tab">Tadım notları</button>{%- endif -%}
      {%- if desc != blank -%}<button type="button" class="eh-tabs__tab" data-eh-tab="d" role="tab">Ürün açıklaması</button>{%- endif -%}
      {%- if dem != blank or ogutum != blank -%}<button type="button" class="eh-tabs__tab" data-eh-tab="b" role="tab">Demleme önerisi</button>{%- endif -%}
      {%- if kargo != blank -%}<button type="button" class="eh-tabs__tab" data-eh-tab="k" role="tab">Teslimat</button>{%- endif -%}
      {%- if show_reviews -%}<button type="button" class="eh-tabs__tab" data-eh-tab="r" role="tab">Yorumlar</button>{%- endif -%}
    </div>

    <div class="eh-tabs__panels">
      {%- if tat != blank -%}
        <div class="eh-tabs__item" data-eh-item="t">
          <div class="eh-tabs__panel rte" data-eh-panel="t" role="tabpanel">{{ tat | newline_to_br }}</div>
        </div>
      {%- endif -%}
      {%- if desc != blank -%}
        <div class="eh-tabs__item" data-eh-item="d">
          <div class="eh-tabs__panel rte" data-eh-panel="d" role="tabpanel">{{ desc }}</div>
        </div>
      {%- endif -%}
      {%- if dem != blank or ogutum != blank -%}
        <div class="eh-tabs__item" data-eh-item="b">
          <div class="eh-tabs__panel" data-eh-panel="b" role="tabpanel">
            {%- if dem != blank -%}{{ dem | newline_to_br }}{%- endif -%}
            {%- if ogutum != blank -%}<p class="eh-tabs__hint"><strong>Önerilen öğütüm:</strong> {{ ogutum }}</p>{%- endif -%}
          </div>
        </div>
      {%- endif -%}
      {%- if kargo != blank -%}
        <div class="eh-tabs__item" data-eh-item="k">
          <div class="eh-tabs__panel rte" data-eh-panel="k" role="tabpanel">{{ kargo }}</div>
        </div>
      {%- endif -%}
      {%- if show_reviews -%}
        <div class="eh-tabs__item" data-eh-item="r">
          <div class="eh-tabs__panel rte" data-eh-panel="r" role="tabpanel">
            {%- if reviews != blank -%}
              {{ reviews }}
            {%- else -%}
              <div class="eh-jdgm-mount" data-eh-jdgm-mount></div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- style -%}
    #shopify-section-{{ section.id }} .eh-tabs { margin: 2.4rem 0 0; }
    /* Sekme şeridi — camsı segmented control (tüm ekranlar) */
    #shopify-section-{{ section.id }} .eh-tabs__strip {
      display: flex; gap: 0.5rem; padding: 0.5rem; margin-bottom: 1.8rem;
      background: rgba(255,252,247,0.62);
      border: 1px solid rgba(255,255,255,0.72);
      border-radius: 16px;
      box-shadow: 0 16px 38px rgba(74,44,23,0.07);
      backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
      overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch;
    }
    #shopify-section-{{ section.id }} .eh-tabs__strip::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .eh-tabs__tab {
      flex: 1 0 auto; appearance: none; cursor: pointer; text-align: center;
      font-family: "Inter", system-ui, sans-serif; font-size: 1.45rem; font-weight: 600;
      color: #5C3A1E; padding: 1.2rem 1.4rem; border-radius: 12px;
      background: transparent; border: none;
      white-space: nowrap; transition: color .18s ease, background .18s ease, box-shadow .18s ease;
    }
    #shopify-section-{{ section.id }} .eh-tabs__tab:hover { background: rgba(176,122,69,0.12); }
    #shopify-section-{{ section.id }} .eh-tabs__tab.is-active {
      color: #FBF3E7; font-weight: 700;
      background: linear-gradient(135deg,#5C3A1E 0%,#8A5A2E 55%,#B07A45 100%);
      box-shadow: 0 3px 10px rgba(124,80,40,0.25);
    }
    #shopify-section-{{ section.id }} .eh-tabs__panel { display: none; }
    #shopify-section-{{ section.id }} .eh-tabs__panel.is-active {
      display: block;
      font-family: "Inter", system-ui, sans-serif; font-size: 1.45rem; line-height: 1.6; color: #6E5947;
      animation: eh-tabfade .2s ease;
    }
    #shopify-section-{{ section.id }} .eh-tabs__panel.rte > :first-child { margin-top: 0; }
    #shopify-section-{{ section.id }} .eh-tabs__hint { margin: 1.2rem 0 0; color: #5C3A1E; }
    /* Judge.me widget tipografisi tema ile hizalı */
    #shopify-section-{{ section.id }} .eh-tabs__panel .jdgm-widget { font-family: "Inter", system-ui, sans-serif; }
    /* Judge.me v3 marka renkleri: widget renklerini inline CSS var ile basıyor
       (--jm-review-widget-*); stylesheet !important inline'ı ezer. */
    #shopify-section-{{ section.id }} .eh-tabs__panel .jm-review-widget,
    #shopify-section-{{ section.id }} .eh-tabs__panel .jdgm-review-widget,
    #shopify-section-{{ section.id }} .eh-tabs__panel .jdgm-review-widget [style*="--jm-review-widget"] {
      --jm-review-widget-star-and-histogram-color: #B07A45 !important;
      --jm-review-widget-button-color: #5C3A1E !important;
      --jm-review-widget-button-text-color: #FBF3E7 !important;
      --jm-review-widget-text-color: #2A1B0E !important;
    }
    #shopify-section-{{ section.id }} .eh-tabs__panel .jm-button { border-radius: 12px; font-weight: 600; }
    @keyframes eh-tabfade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

    /* ---- Mobil: aynı sekme şeridi, biraz kompakt ---- */
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .eh-tabs__strip { gap: 0.4rem; padding: 0.4rem; margin-bottom: 1.4rem; }
      #shopify-section-{{ section.id }} .eh-tabs__tab { font-size: 1.35rem; padding: 1.05rem 1.2rem; }
    }
    @media (prefers-reduced-motion: reduce) {
      #shopify-section-{{ section.id }} .eh-tabs__panel.is-active { animation: none; }
    }
  {%- endstyle -%}

  <script>
    (function () {
      var root = document.getElementById('EhTabs-{{ section.id }}');
      if (!root || root.dataset.ehInit) return;
      root.dataset.ehInit = '1';
      var tabs = [].slice.call(root.querySelectorAll('.eh-tabs__tab'));
      var panels = [].slice.call(root.querySelectorAll('.eh-tabs__panel'));

      function activateTab(key) {
        tabs.forEach(function (t) { t.classList.toggle('is-active', t.getAttribute('data-eh-tab') === key); });
        panels.forEach(function (p) { p.classList.toggle('is-active', p.getAttribute('data-eh-panel') === key); });
      }
      tabs.forEach(function (t) {
        t.addEventListener('click', function () { activateTab(t.getAttribute('data-eh-tab')); });
      });
      // İlk sekme varsayılan aktif (masaüstü + mobil)
      if (panels[0]) activateTab(panels[0].getAttribute('data-eh-panel'));

      // Judge.me v3: şablon sonundaki "apps" section'ında server-render edilen
      // Review Widget app block'unu Yorumlar paneline taşı. Blok yoksa sekmeyi gizle.
      var mount = root.querySelector('[data-eh-jdgm-mount]');
      if (mount) {
        var adoptJdgm = function () {
          var w = document.querySelector('.shopify-app-block .jdgm-review-widget');
          var blockEl = w && w.closest('.shopify-app-block');
          if (blockEl && !mount.contains(blockEl)) {
            mount.appendChild(blockEl);
            return true;
          }
          return !!(w && mount.contains(blockEl));
        };
        var hideReviewsTab = function () {
          var item = root.querySelector('.eh-tabs__item[data-eh-item="r"]');
          var tab = root.querySelector('.eh-tabs__tab[data-eh-tab="r"]');
          if (item) item.remove();
          if (tab) {
            var wasActive = tab.classList.contains('is-active');
            tab.remove();
            if (wasActive && panels[0]) activateTab(panels[0].getAttribute('data-eh-panel'));
          }
        };
        var runAdopt = function () { if (!adoptJdgm()) hideReviewsTab(); };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', runAdopt);
        } else {
          runAdopt();
        }
      }
    })();
  </script>
{%- endif -%}
