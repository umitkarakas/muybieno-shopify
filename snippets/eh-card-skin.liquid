{% comment %} Muybieno — global ürün kartı skin (tüm sayfalar) {% endcomment %}
{%- style -%}
  /* Seal Subscriptions widget'ı quick-add formu olan ürün KARTLARINA da enjekte
     oluyor (koleksiyon/arama/ilgili-ürün grid'lerinde) ve düzeni bozuyordu
     (fiyat üst üste biniyor). Gerçek Seal kökü: .sealsubs-target-element
     (kart varyantı .sls-homepage-automatic). Widget yalnızca gerçek ürün
     sayfası formunda kalsın; kart/quick-add bağlamında gizle.
     ⚠️ .grid__item KULLANMA — Dawn onu PDP ana ürün kolonunda
     (.product__info-wrapper.grid__item) da kullanıyor → PDP widget'ını da
     gizler. Yalnızca kart-özel .card-wrapper / .quick-add ile scope'la.
     (Class doğru; canlı DOM'dan çıkarıldı — eski "sealsubscriptions" ön eki
     yanlıştı, hiç tutmuyordu.) */
  .card-wrapper .sealsubs-target-element,
  .card-wrapper [class*="sealsubs"],
  .quick-add .sealsubs-target-element,
  .quick-add [class*="sealsubs"] {
    display: none !important;
  }

  .card-wrapper {
    --eh-primary: #5C3A1E;
    --eh-primary-hover: #4A2C17;
    --eh-primary-tint: rgba(92, 58, 30, 0.10);
    --eh-outline: #E3D3BC;
    --eh-on-surface: #2A1B0E;
    --font-head: "Bricolage Grotesque", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
    position: relative;
    /* Kartın kendi stacking context'ini kur: quick-add "+" (z-index:3) kök
       bağlama sızıp sticky header'la (z-index:3) eşitlenmesin (menünün üstüne
       çıkma hatası). */
    isolation: isolate;
  }

  .card-wrapper .card__media,
  .card-wrapper .card__media .media { border-radius: 1rem; overflow: hidden; }

  /* Kartları satırda eşit yüksekliğe çek (alta sabitleme için) */
  .card-wrapper, .card-wrapper .card { height: 100%; }

  /* Yalnızca fiyat içeren içerik bloğunu tam yükseklik flex kolon yap (rozet bloğunu değil) */
  .card-wrapper .card__content:has(.price) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .card-wrapper .card__information:has(.price) {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }
  .card-wrapper .card__content { padding-top: 1rem; padding-bottom: 1.4rem; }

  /* Sola hizalı içerik */
  .card-wrapper .card__information { text-align: left; }
  .card-wrapper .card__information .caption-with-letter-spacing { text-align: left; }
  .card-wrapper .card__information .rating { text-align: left; justify-content: flex-start; margin-bottom: 0.4rem; }
  .card-wrapper .card__heading {
    font-family: var(--font-head);
    font-weight: 600;
    line-height: 1.3;
    text-align: left;
  }
  /* Başlığı 2 satıra sabitle → fiyat tüm kartlarda aynı hizada başlar */
  .card-wrapper .card__heading,
  .card-wrapper .card__heading a {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-wrapper .card__heading { min-height: 2.6em; }

  /* Fiyat + "+" tek satır, kartın altında (JS ile sarılır) */
  .card-wrapper .eh-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.8rem;
  }
  .card-wrapper .card__information .price {
    text-align: left;
    margin: 0;
  }
  .card-wrapper .card__information .price__regular .price-item--regular,
  .card-wrapper .card__information .price--on-sale .price-item--sale {
    font-family: var(--font-head);
    font-weight: 700;
    color: var(--eh-primary);
  }
  .card-wrapper .rating-star { --color-rating-star: 217, 154, 43; }

  /* Daire "+" — satır içinde, fiyatla aynı hizada */
  .card-wrapper .quick-add {
    flex-shrink: 0;
    width: auto;
    margin: 0;
    z-index: 3;
  }
  /* JS sarmadıysa (fallback) sağ-altta dursun */
  .card-wrapper .card > .quick-add {
    position: absolute;
    right: 0.4rem;
    bottom: 1.4rem;
  }
  .card-wrapper .quick-add__submit {
    width: 4.4rem;
    height: 4.4rem;
    min-width: 0;
    min-height: 0;
    padding: 0;
    border-radius: 50% !important;
    background: linear-gradient(135deg,#5C3A1E,#8A5A2E) !important;
    color: #fff !important;
    border: none !important;
    font-size: 0 !important;
    box-shadow: 0 4px 12px rgba(92, 58, 30, 0.22);
    position: relative;
    transition: background .15s ease, transform .15s ease;
  }
  .card-wrapper .quick-add__submit:hover { background: var(--eh-primary-hover) !important; transform: translateY(-2px); }
  .card-wrapper .quick-add__submit::after { display: none; }
  .card-wrapper .quick-add__submit::before {
    content: "+";
    font-family: var(--font-body);
    font-size: 2.6rem;
    font-weight: 400;
    line-height: 1;
    position: absolute;
    inset: 0;
    z-index: 2;
    box-shadow: none;
    color: #fff;
    display: grid;
    place-items: center;
  }

  /* İndirim oranı rozeti — kırmızı kare kutucuk */
  .eh-disc-badge {
    background: #C0392B !important;
    color: #fff !important;
    border: none !important;
    border-radius: 6px !important;
    padding: 0.5rem 0.9rem !important;
    font-family: "Inter", system-ui, sans-serif !important;
    font-weight: 800 !important;
    font-size: 1.2rem !important;
    letter-spacing: 0.01em;
    line-height: 1;
    box-shadow: 0 4px 12px rgba(124,40,30,0.3) !important;
    text-transform: none !important;
  }

  /* Abonelenebilir kartta "+" → satın-alma seçenekleri paneli (Seal widget'ı)
     fiyat satırının ÜSTÜNDE popover olarak açılır (PDP'deki gibi). Seal, kartta
     widget içeriğini (.sealsubs-container) display:none ile collapse ediyor →
     açıkken zorla göster. Widget formun içinde kaldığı için abonelik uygulanır. */
  .card-wrapper .eh-price-row { position: relative; }
  .card-wrapper .sealsubs-target-element { display: none !important; }
  .card-wrapper.eh-sub-open .sealsubs-target-element {
    display: block !important;
    position: absolute; left: 0; right: 0; bottom: calc(100% + 0.6rem); z-index: 6;
    background: #FFFCF7; border: 1px solid var(--eh-outline); border-radius: 1rem;
    box-shadow: 0 14px 34px rgba(74,44,23,0.22);
    padding: 0.8rem 1rem; max-height: 62vh; overflow: auto;
  }
  .card-wrapper.eh-sub-open .sealsubs-container { display: block !important; }
  /* Dawn .quick-add'e position:relative veriyor → popover ona (44px "+") tutunup
     dar şerit oluyordu. Açıkken static yap → popover geniş .eh-price-row'a tutunur. */
  .card-wrapper.eh-sub-open .quick-add { position: static; }
  /* Panel içi "Sepete ekle" */
  .eh-sub-add {
    display: block; width: 100%; margin-top: 0.8rem; border: none; cursor: pointer;
    font-family: var(--font-body); font-weight: 700; font-size: 1.35rem;
    color: #FBF3E7; border-radius: 0.8rem; padding: 1.1rem;
    background: linear-gradient(135deg,#5C3A1E 0%,#8A5A2E 55%,#B07A45 100%);
  }
  .eh-sub-add:active { filter: brightness(0.96); }
  /* "+" açıkken aktif görünsün */
  .card-wrapper.eh-sub-open .quick-add__submit { background: var(--eh-primary-hover) !important; }
{%- endstyle -%}

<script>
  (function () {
    function wrapCards(root) {
      (root || document).querySelectorAll('.card-wrapper').forEach(function (card) {
        if (card.dataset.ehRow) return;
        var price = card.querySelector('.card__information .price');
        var info = price && price.closest('.card__information');
        var qa = card.querySelector('.quick-add');
        if (!info || !price || !qa) return;
        card.dataset.ehRow = '1';
        var row = document.createElement('div');
        row.className = 'eh-price-row';
        price.parentNode.insertBefore(row, price);
        row.appendChild(price);
        row.appendChild(qa);

        /* Tüm kartı tıklanabilir yap (görsel dahil) → ürün detaya git */
        var link = card.querySelector('.card__heading a');
        if (link && link.getAttribute('href')) {
          var url = link.getAttribute('href');
          card.style.cursor = 'pointer';
          card.addEventListener('click', function (e) {
            if (e.target.closest('a, button, .quick-add, [role="button"]')) return;
            if (window.getSelection && window.getSelection().toString()) return;
            window.location.href = url;
          });
        }
      });
    }
    /* Abonelenebilir kartta (Seal widget'ında gerçek radio var): "+" doğrudan
       eklemez → satın-alma seçenekleri panelini (Seal widget) fiyat satırının
       üstünde açar (PDP'deki gibi). Panele "Sepete ekle" eklenir → form submit
       (seçilen tek-seferlik/abone uygulanır). Boş/abonelenemez üründe dokunulmaz
       (+ normal ekler). Seal async → MutationObserver'dan da çağrılır. */
    function setupCardSub(root) {
      (root || document).querySelectorAll('.card-wrapper').forEach(function (card) {
        if (card.dataset.ehSub) return;
        var seal = card.querySelector('.sealsubs-target-element');
        if (!seal || !seal.querySelector('input[type="radio"]')) return;
        var submit = card.querySelector('.quick-add__submit') || card.querySelector('.quick-add button[name="add"]');
        var form = card.querySelector('.quick-add form') || card.querySelector('.quick-add product-form');
        if (!submit || !form) return;
        card.dataset.ehSub = '1';
        /* "+" → paneli aç (direkt eklemesin) */
        submit.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var open = card.classList.toggle('eh-sub-open');
          if (open) {
            document.querySelectorAll('.card-wrapper.eh-sub-open').forEach(function (o) { if (o !== card) o.classList.remove('eh-sub-open'); });
          }
        }, true);
        /* Panel içine "Sepete ekle" */
        if (!seal.querySelector('.eh-sub-add')) {
          var addBtn = document.createElement('button');
          addBtn.type = 'button';
          addBtn.className = 'eh-sub-add';
          addBtn.textContent = 'Sepete ekle';
          addBtn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            if (form.requestSubmit) form.requestSubmit(); else if (form.submit) form.submit();
            card.classList.remove('eh-sub-open');
          });
          seal.appendChild(addBtn);
        }
      });
    }
    /* Panel dışına tıklayınca kapat */
    document.addEventListener('click', function (e) {
      if (e.target.closest('.eh-sub-open .sealsubs-target-element')) return;
      if (e.target.closest('.eh-sub-open .quick-add__submit')) return;
      document.querySelectorAll('.card-wrapper.eh-sub-open').forEach(function (o) { o.classList.remove('eh-sub-open'); });
    });
    function run() { wrapCards(document); setupCardSub(document); }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
    else run();
    var pending = false;
    new MutationObserver(function () {
      if (pending) return;
      pending = true;
      requestAnimationFrame(function () { pending = false; wrapCards(document); setupCardSub(document); });
    }).observe(document.body, { childList: true, subtree: true });
    /* Seal widget'ı async/gecikmeli dolduğu için observer bazen kaçırıyor →
       birkaç kez tekrar dene (idempotent: data-eh-sub'lı kartlar atlanır). */
    [400, 1200, 2500, 4500, 7000].forEach(function (t) { setTimeout(function () { setupCardSub(document); }, t); });
    document.addEventListener('sealsubs:loaded', function () { setupCardSub(document); });
    window.addEventListener('load', function () { setupCardSub(document); });
  })();
</script>

