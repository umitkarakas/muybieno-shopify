{% comment %} Muybieno — koyu espresso footer giydirmesi {% endcomment %}
{%- style -%}
  .footer {
    background-color: #2A1B0E !important;
    background-image: none !important;
    color: #f2f0f0 !important;
  }
  .footer .footer-block__heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    color: #E8D5B5 !important;
    
    letter-spacing: 0.1em;
    font-size: 1.3rem;
    font-weight: 600;
  }
  .footer .footer-block__details-content,
  .footer .rte,
  .footer p,
  .footer li { color: rgba(242, 240, 240, 0.72); }
  .footer a { color: rgba(242, 240, 240, 0.72) !important; text-decoration: none; }
  .footer a:hover { color: #fff !important; }

  .footer .footer__content-bottom,
  .footer .footer__copyright,
  .footer .copyright__content,
  .footer small { color: rgba(242, 240, 240, 0.55) !important; }
  .footer .footer__content-bottom { border-top: 1px solid rgba(242, 240, 240, 0.12); }

  /* Bülten */
  .footer .newsletter-form__field-wrapper .field__input,
  .footer .newsletter-form input[type="email"] {
    background: rgba(255, 255, 255, 0.06) !important;
    border-color: rgba(242, 240, 240, 0.25) !important;
    color: #fff !important;
  }
  .footer .newsletter-form__field-wrapper .field__input::placeholder { color: rgba(242, 240, 240, 0.5) !important; }
  .footer .newsletter-form__label { color: rgba(242, 240, 240, 0.72) !important; }
  .footer .newsletter-form__button,
  .footer .newsletter-form__button .icon { color: #E8D5B5 !important; }

  /* Sosyal ikonlar */
  .footer .list-social__link { color: rgba(242, 240, 240, 0.72); }
  .footer .list-social__link:hover { color: #fff; }
{%- endstyle -%}
