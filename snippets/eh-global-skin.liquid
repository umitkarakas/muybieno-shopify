{% comment %} Muybieno — site geneli başlık + buton giydirmesi (kahve/krem) {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- style -%}
  /* Marka token'ları */
  :root {
    --mb-espresso: #5C3A1E;
    --mb-espresso-deep: #2A1B0E;
    --mb-umber: #8A5A2E;
    --mb-caramel: #B07A45;
    --mb-cream: #FBF3E7;
    --mb-ink: #2A1B0E;
    --mb-muted: #8A7560;
    --mb-grad: linear-gradient(135deg, #5C3A1E 0%, #8A5A2E 55%, #B07A45 100%);
    --mb-font-head: "Bricolage Grotesque", system-ui, sans-serif;
    --mb-font-body: "Inter", system-ui, sans-serif;
  }

  /* Gövde / arayüz fontu */
  .template-index, main, .shopify-section { font-family: var(--mb-font-body); }

  /* Başlıklar — Bricolage Grotesque (zarif serif) */
  .template-index h1, .template-index h2, .template-index h3,
  main .title, main .title-wrapper h2,
  .rich-text__heading, .slideshow__text .h1, .slideshow__text .h0,
  .banner__heading, .collection-list-title, .multicolumn .title {
    font-family: var(--mb-font-head);
    font-weight: 600;
    letter-spacing: -0.005em;
  }

  /* Bölüm başlığı */
  main .title-wrapper-with-link .title { font-weight: 600; }

  /* Birincil butonlar — espresso gradyan (sade .button dahil; secondary/tertiary hariç) */
  main .button:not(.button--secondary):not(.button--tertiary),
  .shopify-section .button:not(.button--secondary):not(.button--tertiary) {
    --color-button: 92, 58, 30;
    --color-button-text: 251, 243, 231;
    --alpha-button-background: 1;
    --alpha-button-border: 1;
    background: var(--mb-grad) !important;
    color: var(--mb-cream) !important;
    border: none !important;
    border-radius: 0.85rem;
    font-family: var(--mb-font-body);
    font-weight: 700;
    box-shadow: 0 14px 28px rgba(124, 80, 40, 0.24);
    transition: transform .2s, filter .2s, box-shadow .2s;
  }
  main .button:not(.button--secondary):not(.button--tertiary):hover,
  .shopify-section .button:not(.button--secondary):not(.button--tertiary):hover {
    filter: brightness(1.06);
    transform: translateY(-2px);
  }
  main .button:not(.button--secondary):not(.button--tertiary)::after,
  .shopify-section .button:not(.button--secondary):not(.button--tertiary)::after { display: none !important; }

  /* İkincil butonlar — camsı krem */
  main .button--secondary,
  .shopify-section .button--secondary {
    background: rgba(255, 255, 255, 0.6) !important;
    color: #3A2818 !important;
    border: 1px solid rgba(255, 255, 255, 0.8) !important;
    border-radius: 0.85rem;
    font-family: var(--mb-font-body);
    font-weight: 700;
    -webkit-backdrop-filter: blur(20px);
    backdrop-filter: blur(20px);
    box-shadow: 0 12px 28px rgba(74, 44, 23, 0.06);
    transition: transform .2s, background .2s;
  }
  main .button--secondary:hover,
  .shopify-section .button--secondary:hover {
    background: rgba(255, 255, 255, 0.85) !important;
    transform: translateY(-2px);
  }
  main .button--secondary::after,
  .shopify-section .button--secondary::after { display: none !important; }

  /* ---- Sepet (drawer + sayfa) ---- */
  .cart-item__name,
  .cart-drawer .cart-item__name {
    font-family: var(--mb-font-head);
    font-weight: 600;
  }
  .cart-item__name:hover { color: var(--mb-espresso); }
  .cart-item__final-price,
  .totals__total-value,
  .totals__subtotal-value { color: var(--mb-espresso); font-family: var(--mb-font-head); font-weight: 700; }

  /* Ödeme butonu — espresso gradyan */
  .cart__checkout-button {
    background: var(--mb-grad) !important;
    color: var(--mb-cream) !important;
    border: none !important;
    border-radius: 0.85rem;
  }
  .cart__checkout-button:hover { filter: brightness(1.06); }
  .cart__checkout-button::after { display: none !important; }

  /* Drawer başlığı */
  .cart-drawer .drawer__heading,
  .drawer__header .drawer__heading {
    font-family: var(--mb-font-head);
    font-weight: 600;
  }

  /* Adet stepper + sil + checkbox */
  .cart .quantity__button:hover,
  .cart-drawer .quantity__button:hover { color: var(--mb-espresso); }
  .cart-remove-button,
  .cart-remove-button .icon { color: var(--mb-umber); }
  .cart input[type="checkbox"],
  .cart-drawer input[type="checkbox"] { accent-color: var(--mb-espresso); }

  /* ---- Sepet SAYFASI (drawer'ı etkilemez) ---- */
  /* Başlık — Bricolage espresso */
  .cart__warnings .title,
  .cart .title--primary,
  #main-cart-items .title--primary {
    font-family: var(--mb-font-head);
    font-weight: 600;
    color: #2A1B0E;
  }
  /* Satır öğeleri tablosunu camsı krem karta çevir */
  .cart__items {
    border-radius: 18px;
    background: rgba(255,252,247,0.62);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.72);
    box-shadow: 0 14px 34px rgba(74,44,23,0.06);
    padding: 0.4rem 2rem;        /* yatay padding: tablo başlıkları yuvarlak köşede kırpılmasın */
  }
  /* taşmayı önle ama köşeleri yine yuvarlak tut */
  .cart__items .cart-items { overflow: visible; }
  .cart__items .cart-item { border-color: rgba(92,58,30,0.10); }
  /* Sipariş özeti / footer — camsı krem panel */
  .cart__footer {
    border-radius: 22px;
    background: rgba(255,252,247,0.7);
    -webkit-backdrop-filter: blur(22px);
    backdrop-filter: blur(22px);
    border: 1px solid rgba(255,255,255,0.75);
    box-shadow: 0 22px 54px rgba(74,44,23,0.10);
    padding: 2.4rem;            /* iç boşluk: not alanı/toplam kenara yapışmasın */
    margin-top: 1.6rem;         /* satır kartından ayrıl */
  }
  .cart__footer .cart__note { margin-bottom: 1.6rem; }
  .cart__footer .cart__note textarea { border-radius: 1.1rem; }
  @media screen and (max-width: 749px) {
    .cart__footer { padding: 2rem 1.6rem; }
  }
  /* Satır fiyatları Bricolage espresso */
  .cart-item__price-wrapper .price,
  .cart-item__totals .price { font-family: var(--mb-font-head); font-weight: 700; color: var(--mb-espresso); }
  /* "Alışverişe devam" / boş sepet linki */
  .cart__empty-text + .button,
  .cart-page__continue { border-radius: 0.85rem; }

  /* ---- Hesap / giriş (customer) ---- */
  .customer__title,
  .customer h1, .customer h2, .customer h3 {
    font-family: var(--mb-font-head);
    letter-spacing: -0.005em;
  }
  .customer .button {
    background: var(--mb-grad) !important;
    color: var(--mb-cream) !important;
    border: none !important;
    border-radius: 0.85rem;
    font-family: var(--mb-font-body);
    font-weight: 700;
  }
  .customer .button:hover { filter: brightness(1.06); }
  .customer .button::after { display: none !important; }
  .customer a:not(.button) { color: var(--mb-espresso); }
  .customer .field__input:focus,
  .customer input:focus {
    border-color: var(--mb-espresso) !important;
    box-shadow: 0 0 0 3px rgba(92, 58, 30, 0.12) !important;
  }

  /* ---- Arama ---- */
  .search__input:focus,
  .search-modal .field__input:focus {
    border-color: var(--mb-espresso) !important;
    box-shadow: 0 0 0 3px rgba(92, 58, 30, 0.12) !important;
  }
  .search__button:hover .icon,
  .search__button:hover { color: var(--mb-espresso); }
  .predictive-search__item:hover,
  .predictive-search__item[aria-selected="true"] { background: rgba(92, 58, 30, 0.06); }
  .predictive-search__heading { color: var(--mb-umber); font-family: var(--mb-font-head); font-weight: 600; }

  /* ---- Ana sayfa slider (slideshow) kontrolleri ---- */
  .slideshow__controls .slider-button .icon,
  .slideshow__controls .slider-button:hover .icon,
  .slideshow__autoplay .icon { color: var(--mb-espresso); }
  .slider-counter__link--active.slider-counter__link--dots .dot {
    background-color: var(--mb-espresso) !important;
    border-color: var(--mb-espresso) !important;
  }
  .slider-counter__link--dots:not(.slider-counter__link--active):hover .dot {
    background-color: rgba(92, 58, 30, 0.5) !important;
  }
  .slider-counter__link--active.slider-counter__link--numbers {
    color: var(--mb-espresso) !important;
    border-color: var(--mb-espresso) !important;
  }
  /* Hero serif başlık karakteri */
  .slideshow__text .banner__heading { font-weight: 600; }

  /* Hero / banner CTA — espresso gradyan (secondary olsa da birincil) */
  .banner__buttons .button:not(.button--secondary),
  .slideshow__text .button:not(.button--secondary),
  .banner__content .button:not(.button--secondary) {
    background: var(--mb-grad) !important;
    color: var(--mb-cream) !important;
    border: none !important;
    border-radius: 0.85rem;
    font-weight: 700;
  }
  .banner__buttons .button:not(.button--secondary):hover,
  .slideshow__text .button:not(.button--secondary):hover,
  .banner__content .button:not(.button--secondary):hover { filter: brightness(1.06); transform: translateY(-2px); }
  .banner__buttons .button::after,
  .slideshow__text .button::after { display: none !important; }

  /* ---- Mobil ince ayar ---- */
  @media screen and (max-width: 749px) {
    .slideshow__text .banner__heading { font-size: 3.6rem; line-height: 1.1; }
    .slideshow__text .banner__text { font-size: 1.5rem; }
    .slideshow__text-wrapper .slideshow__text { padding: 2.4rem 2rem 2.8rem; }
  }
{%- endstyle -%}
