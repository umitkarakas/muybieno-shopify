{% comment %}
  Muybieno — ürün meta grid (Bölge/Rakım/Kavrum/İşleme).
  Kaynak: product metafield'ları custom.bolge / custom.rakim / custom.kavrum / custom.isleme
  2×2 camsı ikon kart; mobilde yatay scroll-snap carousel. Boş metafield'lı kart atlanır.
{% endcomment %}
{%- liquid
  assign mf = product.metafields.custom
  assign has_any = false
  if mf.bolge != blank or mf.rakim != blank or mf.kavrum != blank or mf.isleme != blank or mf.mensei != blank
    assign has_any = true
  endif
-%}

{%- if has_any -%}
  <div class="eh-meta" {{ block.shopify_attributes }}>
    {%- if mf.bolge != blank -%}
      <div class="eh-meta__card">
        <span class="eh-meta__ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <span class="eh-meta__txt"><span class="eh-meta__lbl">Bölge</span><span class="eh-meta__val">{{ mf.bolge }}</span></span>
      </div>
    {%- endif -%}
    {%- if mf.rakim != blank -%}
      <div class="eh-meta__card">
        <span class="eh-meta__ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m8 3 4 8 5-5 5 15H2L8 3z"/></svg>
        </span>
        <span class="eh-meta__txt"><span class="eh-meta__lbl">Rakım</span><span class="eh-meta__val">{{ mf.rakim }}</span></span>
      </div>
    {%- endif -%}
    {%- if mf.kavrum != blank -%}
      <div class="eh-meta__card">
        <span class="eh-meta__ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
        </span>
        <span class="eh-meta__txt"><span class="eh-meta__lbl">Kavrum</span><span class="eh-meta__val">{{ mf.kavrum }}</span></span>
      </div>
    {%- endif -%}
    {%- if mf.isleme != blank -%}
      <div class="eh-meta__card">
        <span class="eh-meta__ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
        </span>
        <span class="eh-meta__txt"><span class="eh-meta__lbl">İşleme</span><span class="eh-meta__val">{{ mf.isleme }}</span></span>
      </div>
    {%- endif -%}
    {%- if mf.mensei != blank -%}
      <div class="eh-meta__card">
        <span class="eh-meta__ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </span>
        <span class="eh-meta__txt"><span class="eh-meta__lbl">Menşei</span><span class="eh-meta__val">{{ mf.mensei }}</span></span>
      </div>
    {%- endif -%}
  </div>

  {%- style -%}
    #shopify-section-{{ section.id }} .eh-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin: 2rem 0 0;
    }
    #shopify-section-{{ section.id }} .eh-meta__card {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      padding: 0.85rem 1.1rem;
      border-radius: 1.3rem;
      background: rgba(255,252,247,0.55);
      -webkit-backdrop-filter: blur(18px);
      backdrop-filter: blur(18px);
      border: 1px solid rgba(255,255,255,0.7);
      box-shadow: 0 12px 30px rgba(74,44,23,0.06);
    }
    #shopify-section-{{ section.id }} .eh-meta__ico {
      flex: none;
      width: 3.6rem;
      height: 3.6rem;
      border-radius: 1.1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg,#5C3A1E,#8A5A2E);
      color: #FBF3E7;
    }
    #shopify-section-{{ section.id }} .eh-meta__ico svg { width: 1.8rem; height: 1.8rem; }
    #shopify-section-{{ section.id }} .eh-meta__txt { display: flex; flex-direction: column; min-width: 0; }
    #shopify-section-{{ section.id }} .eh-meta__lbl {
      font-family: "Inter", system-ui, sans-serif;
      font-size: 1.1rem; font-weight: 600; color: #9C8773;
    }
    #shopify-section-{{ section.id }} .eh-meta__val {
      font-family: "Inter", system-ui, sans-serif;
      font-size: 1.35rem; font-weight: 700; color: #3A2818;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    /* Mobil: yatay scroll-snap carousel */
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .eh-meta {
        grid-template-columns: none;
        grid-auto-flow: column;
        grid-auto-columns: 78%;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
        margin-inline: -1.5rem;       /* kenara taşıp tam genişlik kayma */
        padding-inline: 1.5rem;
      }
      #shopify-section-{{ section.id }} .eh-meta::-webkit-scrollbar { display: none; }
      #shopify-section-{{ section.id }} .eh-meta__card { scroll-snap-align: start; }
    }
  {%- endstyle -%}
{%- endif -%}
