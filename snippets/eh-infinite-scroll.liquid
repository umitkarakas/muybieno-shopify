{%- comment -%}
  Muybieno — sonsuz kaydırma. Numaralı sayfalama gizlenir; sayfa sonuna gelince
  sonraki sayfa fetch edilip mevcut grid'e eklenir. Koleksiyon + blog ortak.
  Parametreler:
    scope_id      → section.id (pagination-wrapper'ı gizlemek + section'ı bulmak için)
    grid_selector → öğelerin bulunduğu kapsayıcı (ör. "#product-grid", ".blog-articles")
    item_selector → eklenecek tekil öğe (ör. "li", ".blog-articles__article")
{%- endcomment -%}
<div id="EhInf-{{ scope_id }}" class="eh-infinite" aria-hidden="true">
  <div class="eh-infinite__spinner" data-eh-spinner><span></span></div>
</div>

{%- style -%}
  #shopify-section-{{ scope_id }} .pagination-wrapper { display: none !important; }
  #EhInf-{{ scope_id }} { width: 100%; }
  #EhInf-{{ scope_id }} .eh-infinite__spinner { display: none; justify-content: center; padding: 2.4rem 0; }
  #EhInf-{{ scope_id }} .eh-infinite__spinner.is-on { display: flex; }
  #EhInf-{{ scope_id }} .eh-infinite__spinner span {
    width: 2.4rem; height: 2.4rem; border-radius: 50%;
    border: 2px solid rgba(92,58,30,0.22); border-top-color: #5C3A1E;
    animation: eh-inf-spin .7s linear infinite;
  }
  @keyframes eh-inf-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { #EhInf-{{ scope_id }} .eh-infinite__spinner span { animation: none; } }
{%- endstyle -%}

<script>
  (function () {
    var root = document.getElementById('EhInf-{{ scope_id }}');
    if (!root || root.dataset.on) return;
    root.dataset.on = '1';
    var section = document.getElementById('shopify-section-{{ scope_id }}') || document;
    var gridSel = {{ grid_selector | json }};
    var itemSel = {{ item_selector | json }};
    var grid = section.querySelector(gridSel);
    var spinner = root.querySelector('[data-eh-spinner]');
    if (!grid || !spinner) return;

    var loading = false, done = false, url = null;

    function nextUrl(scopeEl) {
      var wrap = (scopeEl || section).querySelector('.pagination-wrapper');
      if (!wrap) return null;
      var cur = parseInt(wrap.getAttribute('data-page') || '1', 10);
      var want = String(cur + 1);
      var links = wrap.querySelectorAll('a.pagination__item');
      for (var i = 0; i < links.length; i++) {
        if (links[i].textContent.trim() === want) return links[i].getAttribute('href');
      }
      var arrow = wrap.querySelector('a.pagination__item--prev');
      return arrow ? arrow.getAttribute('href') : null;
    }

    url = nextUrl(section);
    if (!url) { done = true; return; }

    function appendFrom(doc) {
      var newGrid = doc.querySelector('#shopify-section-{{ scope_id }} ' + gridSel) || doc.querySelector(gridSel);
      if (!newGrid) return;
      var items = newGrid.querySelectorAll(':scope > ' + itemSel);
      for (var i = 0; i < items.length; i++) {
        grid.appendChild(document.importNode(items[i], true));
      }
      var newSection = doc.getElementById('shopify-section-{{ scope_id }}') || doc;
      url = nextUrl(newSection);
      if (!url) done = true;
    }

    function load() {
      if (loading || done || !url) return;
      loading = true;
      spinner.classList.add('is-on');
      fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) { return r.text(); })
        .then(function (html) {
          appendFrom(new DOMParser().parseFromString(html, 'text/html'));
          loading = false;
          spinner.classList.remove('is-on');
          // spinner hâlâ görünürdeyse bir sonraki sayfayı da çek
          io.unobserve(spinner);
          if (!done) io.observe(spinner);
        })
        .catch(function () { loading = false; spinner.classList.remove('is-on'); });
    }

    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) { if (e.isIntersecting) load(); });
    }, { rootMargin: '700px 0px' });
    io.observe(spinner);
  })();
</script>
