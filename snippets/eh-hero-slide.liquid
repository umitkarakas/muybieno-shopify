{%- comment -%}
  Muybieno — sade hero slide: sol renkli panel (rozet + başlık + alt yazı + buton) + sağ görsel.
  s = blok/section ayarları, active = ilk slide mi, attrs = block.shopify_attributes
{%- endcomment -%}
<div class="eh-hero__slide{% if active %} is-active{% endif %}" data-eh-slide {{ attrs }}>
  <div class="eh-hero2__in">
    <div class="eh-hero2__text">
      {%- if s.badge != blank -%}<span class="eh-hero2__badge">{{ s.badge }}</span>{%- endif -%}
      {%- if s.heading != blank -%}<div class="eh-hero2__title">{{ s.heading }}</div>{%- endif -%}
      {%- if s.text != blank -%}<div class="eh-hero2__sub">{{ s.text }}</div>{%- endif -%}
      {%- if s.button_label != blank -%}
        <a class="eh-hero2__btn" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}</a>
      {%- endif -%}
    </div>
    <div class="eh-hero2__media">
      {%- if s.image != blank -%}
        {{ s.image | image_url: width: 1500 | image_tag: loading: 'eager', alt: s.product_label | default: s.badge, sizes: '(max-width: 860px) 100vw, 50vw', widths: '600,900,1200,1500' }}
      {%- else -%}
        <div class="eh-hero2__media-ph" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  </div>
</div>
