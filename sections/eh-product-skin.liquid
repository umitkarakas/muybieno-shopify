<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="page-width eh-crumb-wrap">{% render 'eh-breadcrumb' %}</div>

{%- style -%}
  .eh-crumb-wrap { padding-top: 1.6rem; }
  .eh-product-page {
    --eh-primary: #5C3A1E;
    --eh-primary-hover: #4A2E16;
    --eh-primary-grad: linear-gradient(135deg,#5C3A1E 0%,#8A5A2E 55%,#B07A45 100%);
    --eh-primary-tint: rgba(138, 90, 46, 0.12);
    --eh-secondary: #8A5A2E;
    --eh-caramel: #B07A45;
    --eh-error: #B5482F;
    --eh-stone: rgba(92, 58, 30, 0.18);
    --eh-outline: rgba(255, 255, 255, 0.72);
    --eh-on-surface: #2A1B0E;
    --eh-on-variant: #6E5947;
    --eh-surface: #FFFCF7;
    --eh-r: 0.85rem;
    --eh-r-full: 9999px;
    --font-head: "Bricolage Grotesque", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
  }

  /* ---- Typography ---- */
  .eh-product-page .product__info-container,
  .eh-product-page .product__title,
  .eh-product-page .price {
    font-family: var(--font-body);
  }
  .eh-product-page .product__title,
  .eh-product-page .product__title > * {
    font-family: var(--font-head);
    font-weight: 600;
    letter-spacing: 0;
    color: var(--eh-on-surface);
  }
  /* Başlık boyutu — daha ölçülü (28px / mobil 22px) */
  .eh-product-page .product__title h1 {
    font-size: 2.8rem;
    line-height: 1.15;
  }
  @media screen and (max-width: 749px) {
    .eh-product-page .product__title h1 {
      font-size: 2.2rem;
      line-height: 1.2;
    }
  }

  /* ---- Tighten the section top spacing (breadcrumb area) ---- */
  .eh-product-page main .shopify-section + .shopify-section .product,
  .eh-product-page .product-grid-container { }
  .eh-product-page #MainContent > .shopify-section:first-child { padding-top: 8px; }
  .eh-product-page .product { padding-top: 0; }

  /* ---- Category / type eyebrow (vendor) ---- */
  .eh-product-page .product__text.caption-with-letter-spacing {
    color: var(--eh-secondary);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  /* ---- Price ---- */
  /* Büyük yeşil ana fiyat (yalnızca ürün bilgi sütunu — kartlara sızmasın) */
  .eh-product-page .product__info-container .price__regular .price-item--regular,
  .eh-product-page .product__info-container .price--on-sale .price-item--sale {
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 3.4rem;
    line-height: 1;
    color: var(--eh-primary);
    letter-spacing: -0.02em;
  }
  /* Üstü çizili eski fiyat (ürün bilgi sütunu) */
  .eh-product-page .product__info-container .price__sale s.price-item--regular,
  .eh-product-page .product__info-container .price__sale .price-item--regular {
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--eh-outline);
    font-size: 1.8rem;
    letter-spacing: 0;
  }
  /* Kırmızı indirim rozeti */
  .eh-product-page .price__badge-sale,
  .eh-product-page .badge.price__badge-sale {
    background-color: var(--eh-error) !important;
    color: #fff !important;
    border-color: var(--eh-error) !important;
    border-radius: var(--eh-r-full);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  /* ---- Variant pills ---- */
  .eh-product-page .product-form__input--pill input[type='radio'] + label {
    border: 1.5px solid var(--eh-stone);
    border-radius: var(--eh-r);
    padding: 1.1rem 1.8rem;
    font-weight: 500;
    color: var(--eh-on-surface);
    background: #fff;
    transition: border-color .15s ease, background .15s ease, color .15s ease;
  }
  .eh-product-page .product-form__input--pill input[type='radio'] + label:hover {
    border-color: var(--eh-primary);
  }
  .eh-product-page .product-form__input--pill input[type='radio']:checked + label {
    border-color: var(--eh-primary);
    background: var(--eh-primary-tint);
    color: var(--eh-primary);
    font-weight: 600;
  }
  .eh-product-page .form__label,
  .eh-product-page .product-form__input .form__label {
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--eh-on-variant);
  }

  /* ---- Buttons ---- */
  /* Sepete Ekle her zaman yeşil primary (dynamic checkout açık olsa da) */
  .eh-product-page .product-form__submit,
  .eh-product-page .product-form__submit.button--secondary,
  .eh-product-page .product-form__submit.button--primary,
  .eh-product-page .button--primary {
    background: var(--eh-primary-grad) !important;
    color: #FBF3E7 !important;
    border: none !important;
    border-radius: var(--eh-r);
    font-family: var(--font-body);
    font-weight: 700;
    box-shadow: 0 18px 34px rgba(124, 80, 40, 0.28);
    transition: filter .2s, transform .2s;
  }
  .eh-product-page .product-form__submit:hover,
  .eh-product-page .button--primary:hover { filter: brightness(1.06); transform: translateY(-2px); }
  /* Sense butonlarının ::after iç çerçevesini kaldır (çift kenarlık) */
  .eh-product-page .product-form__submit::after,
  .eh-product-page .button--primary::after,
  .eh-product-page .shopify-payment-button__button--unbranded::after { display: none; }

  /* "Hemen Al" / hızlı ödeme → umber çizgili */
  .eh-product-page .shopify-payment-button__button--unbranded {
    background: #fff !important;
    color: var(--eh-secondary) !important;
    border: 1.5px solid var(--eh-secondary) !important;
    border-radius: var(--eh-r) !important;
  }
  .eh-product-page .shopify-payment-button__button--unbranded:hover {
    background: rgba(137,80,36,.08) !important;
  }
  .eh-product-page .shopify-payment-button__button { border-radius: var(--eh-r); overflow: hidden; }

  /* ---- Quantity stepper ---- */
  .eh-product-page .quantity {
    border: 1px solid var(--eh-stone);
    border-radius: var(--eh-r);
    overflow: hidden;
  }
  .eh-product-page .quantity__button:hover { color: var(--eh-primary); }

  /* ---- Desktop: Adet + Sepete ekle tek satır; Hemen satın al alt satır ---- */
  @media screen and (min-width: 750px) {
    .eh-product-page .product-form__buttons.eh-buy-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      align-items: center;
    }
    .eh-product-page .eh-buy-row .product-form__quantity { flex: 0 0 auto; margin: 0; }
    .eh-product-page .eh-buy-row .product-form__quantity .quantity__label { display: none; }
    .eh-product-page .eh-buy-row .product-form__submit { flex: 1 1 auto; min-width: 50%; margin: 0; }
    .eh-product-page .eh-buy-row .shopify-payment-button { flex: 1 1 100%; margin-top: 0; }
    .eh-product-page .eh-buy-row .product-form__error-message-wrapper { flex: 1 1 100%; }
  }

  /* ---- Stock / availability chip ---- */
  .eh-product-page .product__inventory {
    display: inline-flex;
    align-items: center;
    font-size: 1.2rem;
    font-weight: 600;
    padding: 0.5rem 1.2rem;
    border-radius: var(--eh-r-full);
    background: var(--eh-primary-tint);
    color: var(--eh-primary);
  }

  /* ---- Accordions ---- */
  .eh-product-page .product__accordion .accordion__title,
  .eh-product-page .product__accordion summary {
    font-family: var(--font-head);
    font-weight: 600;
  }

  /* ---- Perk şeridi (icon-with-text) — yatay 3 cam kart, mobilde carousel ---- */
  .eh-product-page .icon-with-text.icon-with-text--vertical {
    display: flex;
    gap: 1rem;
    margin: 0.4rem 0 1.6rem;
    padding: 0;
    border: none;
    border-radius: 0;
    overflow: visible;
    background: none;
  }
  .eh-product-page .icon-with-text--vertical .icon-with-text__item {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.9rem;
    margin: 0;
    padding: 1.4rem;
    width: auto;
    border: 1px solid rgba(255,255,255,0.7);
    border-radius: 1.3rem;
    background: rgba(255,252,247,0.55);
    -webkit-backdrop-filter: blur(18px);
    backdrop-filter: blur(18px);
    box-shadow: 0 12px 30px rgba(74,44,23,0.06);
  }
  .eh-product-page .icon-with-text--vertical .icon-with-text__item + .icon-with-text__item {
    border-top: 1px solid rgba(255,255,255,0.7);
  }
  .eh-product-page .icon-with-text--vertical .svg-wrapper,
  .eh-product-page .icon-with-text--vertical .icon {
    width: 3.6rem;
    height: 3.6rem;
    min-width: 3.6rem;
    min-height: 3.6rem;
    flex-shrink: 0;
    margin: 0;
    padding: 0.9rem;
    box-sizing: border-box;
    border-radius: 1.1rem;
    background: var(--eh-primary-grad);
    color: #FBF3E7;
    fill: #FBF3E7;
  }
  .eh-product-page .icon-with-text--vertical .h4 {
    font-family: var(--font-body);
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    padding: 0;
    text-align: center;
    color: var(--eh-on-surface);
  }
  @media screen and (max-width: 749px) {
    /* Mobilde carousel: dar kartlar, metin 2 satıra sarsın — az yer kaplasın */
    .eh-product-page .icon-with-text.icon-with-text--vertical {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0.9rem;
    }
    .eh-product-page .icon-with-text--vertical::-webkit-scrollbar { display: none; }
    .eh-product-page .icon-with-text--vertical .icon-with-text__item {
      flex: 0 0 44%;
      scroll-snap-align: start;
    }
    .eh-product-page .icon-with-text--vertical .h4 {
      white-space: normal;
      font-size: 1.3rem;
      line-height: 1.25;
    }
  }

  /* ---- İlgili ürünler — mobilde yatay carousel (masaüstü grid kalır) ---- */
  @media screen and (max-width: 749px) {
    .eh-product-page .related-products .product-grid {
      display: flex;
      gap: 1.2rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      margin-inline: -1.5rem;
      padding-inline: 1.5rem;
    }
    .eh-product-page .related-products .product-grid::-webkit-scrollbar { display: none; }
    .eh-product-page .related-products .product-grid > li {
      flex: 0 0 44%;
      scroll-snap-align: start;
      max-width: 44%;
    }
    /* Eksik görselli kart aşırı uzamasın — medya alanını kareye sabitle */
    .eh-product-page .related-products .card__inner { --ratio-percent: 100%; }
    .eh-product-page .related-products .card__media,
    .eh-product-page .related-products .media { aspect-ratio: 1 / 1; }
  }

  /* ---- Akordeonlar ---- */
  .eh-product-page .product__accordion .accordion__title {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.7rem;
  }

  /* ---- Açıklama: daha fazlasını oku ---- */
  .eh-product-page .product__description.eh-clamp {
    max-height: 8.5rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(180deg, #000 55%, transparent);
    mask-image: linear-gradient(180deg, #000 55%, transparent);
  }
  .eh-product-page .product__description.eh-expanded {
    max-height: none;
    -webkit-mask-image: none;
    mask-image: none;
  }
  .eh-product-page .eh-readmore {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.6rem 0 0;
    padding: 0;
    background: none;
    border: none;
    color: var(--eh-primary);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1.4rem;
    cursor: pointer;
  }
  .eh-product-page .eh-readmore:hover { text-decoration: underline; }

  /* ---- Mobil: body-seviyesi sabit alt buton barı ---- */
  .eh-mobile-buybar { display: none; }
  @media screen and (max-width: 749px) {
    .eh-mobile-buybar {
      display: block;
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 40;
      background: #FFFCF7;
      border-top: 1px solid var(--eh-stone);
      box-shadow: 0 -4px 16px rgba(74, 44, 23, 0.12);
      padding: 1rem 1.5rem;
      padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
    }
    .eh-mobile-buybar .eh-buybar__row {
      display: flex;
      align-items: center;
      gap: 1.2rem;
    }
    .eh-mobile-buybar .eh-buybar__price {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      flex-shrink: 0;
      white-space: nowrap;
    }
    .eh-mobile-buybar .eh-bp__top {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      line-height: 1;
    }
    .eh-mobile-buybar .eh-bp__top s { font-size: 1.3rem; font-weight: 500; color: var(--eh-outline); }
    .eh-mobile-buybar .eh-bp__badge { font-size: 1.2rem; font-weight: 700; color: var(--eh-error); }
    .eh-mobile-buybar .eh-bp__now {
      font-family: var(--font-head);
      font-weight: 700;
      font-size: 2rem;
      line-height: 1.05;
      color: var(--eh-on-surface);
    }
    .eh-mobile-buybar product-form,
    .eh-mobile-buybar .product-form { flex: 1; min-width: 0; }
    .eh-mobile-buybar .product-form__buttons { display: block; margin: 0; }
    .eh-mobile-buybar .product-form__submit { width: 100%; margin: 0; }
    .eh-mobile-buybar .shopify-payment-button { display: none; }
    .eh-mobile-buybar .product-form__error-message-wrapper { display: none; }
    /* Adet sayacı — butonun solunda, dikey ▲▼ kompakt */
    .eh-mobile-buybar .product-form__quantity { margin: 0; flex: 0 0 auto; }
    .eh-mobile-buybar .quantity__label,
    .eh-mobile-buybar .quantity__rules,
    .eh-mobile-buybar .quantity__rules-cart { display: none !important; }
    .eh-mobile-buybar .quantity {
      display: grid;
      grid-template-columns: auto 2.8rem;
      grid-template-rows: 2.5rem 2.5rem;
      border: 1px solid var(--eh-stone);
      border-radius: var(--eh-r);
      overflow: hidden;
      width: auto;
      height: auto;
    }
    .eh-mobile-buybar .quantity__input {
      grid-column: 1;
      grid-row: 1 / 3;
      width: 3.2rem;
      height: auto;
      font-weight: 600;
      border-right: 1px solid var(--eh-stone);
    }
    .eh-mobile-buybar .quantity__button {
      width: 2.8rem;
      min-width: 0;
      height: auto;
      padding: 0;
      color: var(--eh-on-surface);
    }
    .eh-mobile-buybar .quantity__button:hover { color: var(--eh-primary); }
    .eh-mobile-buybar .quantity__button .svg-wrapper,
    .eh-mobile-buybar .quantity__button svg { display: none; }
    .eh-mobile-buybar .quantity__button[name='plus'] {
      grid-column: 2;
      grid-row: 1;
      border-bottom: 1px solid var(--eh-stone);
    }
    .eh-mobile-buybar .quantity__button[name='minus'] { grid-column: 2; grid-row: 2; }
    .eh-mobile-buybar .quantity__button[name='plus']::after { content: '▲'; font-size: 1rem; line-height: 1; }
    .eh-mobile-buybar .quantity__button[name='minus']::after { content: '▼'; font-size: 1rem; line-height: 1; }
    /* Mobilde üstteki fiyat mükerrer olmasın (bar fiyatı bundan beslenir, gizli okunur) */
    .eh-product-page .product__info-container .price { display: none; }
    /* alt barın altında içerik gizlenmesin */
    .eh-product-page #MainContent { padding-bottom: 12rem; }
  }

  /* Ürün kartı stilleri global snippet'e taşındı: snippets/eh-card-skin.liquid */

  /* ---- Sütun bölünmesi: desktop'ta %50/%50 (galeri çok büyük olmasın) ---- */
  @media screen and (min-width: 990px) {
    .eh-product-page .product:not(.product--no-media) .product__media-wrapper {
      max-width: 50%;
      width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2);
    }
    .eh-product-page .product:not(.product--no-media) .product__info-wrapper {
      max-width: 50%;
      width: calc(50% - var(--grid-desktop-horizontal-spacing) / 2);
    }
  }

  /* ---- Adım 1: Galeri (yuvarlak kart + thumbnail) ---- */
  .eh-product-page .product__media-item .media,
  .eh-product-page .product__media-item--single .media {
    border-radius: 1.5rem;
    background: #FFFCF7;
    box-shadow: 0 26px 60px rgba(58, 34, 15, 0.12), 0 2px 6px rgba(74, 44, 23, 0.05);
    overflow: hidden;
  }
  /* Kare format YALNIZCA mobilde — dikey alan tasarrufu (desktop'ta doğal oran kalsın).
     Dawn oranı .product-media-container .media { padding-top: var(--ratio-percent) } ile
     verir; doğrudan padding-top:100% ile kareye sabitliyoruz. */
  @media screen and (max-width: 749px) {
    .eh-product-page .product-media-container { --aspect-ratio: 1 !important; --ratio-percent: 100% !important; }
    .eh-product-page .product-media-container .media {
      padding-top: 100% !important;
    }
    .eh-product-page .product-media-container .media img {
      object-fit: contain;
    }
  }
  .eh-product-page .product__media-item img.media,
  .eh-product-page .product__media-item .media img {
    border-radius: 1.5rem;
  }
  /* thumbnail'lar */
  .eh-product-page .thumbnail-list__item .thumbnail {
    border-radius: 0.75rem;
    border: 2px solid transparent;
    overflow: hidden;
    transition: border-color .15s ease;
  }
  .eh-product-page .thumbnail-list__item .thumbnail::after { display: none; }
  .eh-product-page .thumbnail-list__item .thumbnail[aria-current],
  .eh-product-page .thumbnail-list__item .thumbnail[aria-current="true"] {
    border-color: var(--eh-primary);
    box-shadow: none;
  }
{%- endstyle -%}

<script>
  document.body.classList.add('eh-product-page');
  (function () {
    function initReadMore() {
      var desc = document.querySelector('.eh-product-page .product__description');
      if (!desc || desc.dataset.ehReadmore) return;
      desc.dataset.ehReadmore = '1';
      var threshold = 150;
      if (desc.scrollHeight <= threshold + 24) return;
      desc.classList.add('eh-clamp');
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'eh-readmore';
      btn.textContent = 'Daha fazlasını oku';
      desc.parentNode.insertBefore(btn, desc.nextSibling);
      btn.addEventListener('click', function () {
        var expanded = desc.classList.toggle('eh-expanded');
        desc.classList.toggle('eh-clamp', !expanded);
        btn.textContent = expanded ? 'Daha az göster' : 'Daha fazlasını oku';
      });
    }
    /* Mobilde buton formunu body'ye taşıyıp sabit alt bara koy */
    function initStickyBar() {
      var form = document.querySelector('.eh-product-page product-form.product-form')
              || document.querySelector('.eh-product-page .product-form');
      if (!form) return;
      var priceEl = document.querySelector('.eh-product-page .product__info-container .price')
                 || document.querySelector('.eh-product-page .price');
      var qty = document.querySelector('.eh-product-page .product-form__quantity');
      var mq = window.matchMedia('(max-width: 749px)');
      var bar = null, row = null, priceWrap = null;
      var placeholder = document.createComment('eh-buybar');
      form.parentNode.insertBefore(placeholder, form);
      var qtyPlaceholder = null;
      if (qty) { qtyPlaceholder = document.createComment('eh-qty'); qty.parentNode.insertBefore(qtyPlaceholder, qty); }

      function parseNum(t) {
        if (!t) return NaN;
        t = t.replace(/[^\d.,]/g, '');
        if (t.indexOf(',') > -1) { t = t.replace(/\./g, '').replace(',', '.'); }
        return parseFloat(t);
      }

      function syncPrice() {
        if (!priceWrap || !priceEl) return;
        var onSale = priceEl.classList.contains('price--on-sale');
        var curNode = onSale
          ? priceEl.querySelector('.price__sale .price-item--sale')
          : priceEl.querySelector('.price__regular .price-item--regular');
        var oldNode = onSale ? priceEl.querySelector('.price__sale s.price-item--regular') : null;
        var curText = curNode ? curNode.textContent.trim() : '';
        var oldText = oldNode ? oldNode.textContent.trim() : '';

        priceWrap.innerHTML = '';
        if (oldText) {
          var top = document.createElement('div');
          top.className = 'eh-bp__top';
          var s = document.createElement('s');
          s.textContent = oldText;
          top.appendChild(s);
          var pct = Math.round((parseNum(oldText) - parseNum(curText)) / parseNum(oldText) * 100);
          if (!isNaN(pct) && pct > 0) {
            var b = document.createElement('span');
            b.className = 'eh-bp__badge';
            b.textContent = '%' + pct;
            top.appendChild(b);
          }
          priceWrap.appendChild(top);
        }
        var now = document.createElement('div');
        now.className = 'eh-bp__now';
        now.textContent = curText;
        priceWrap.appendChild(now);
      }

      function place() {
        if (mq.matches) {
          if (!bar) {
            bar = document.createElement('div');
            bar.className = 'eh-mobile-buybar';
            row = document.createElement('div');
            row.className = 'eh-buybar__row';
            priceWrap = document.createElement('div');
            priceWrap.className = 'eh-buybar__price';
            row.appendChild(priceWrap);
            bar.appendChild(row);
            document.body.appendChild(bar);
            if (priceEl && window.MutationObserver) {
              new MutationObserver(syncPrice).observe(priceEl, { childList: true, subtree: true, characterData: true });
            }
          }
          if (qty && qty.parentNode !== row) row.appendChild(qty);
          if (form.parentNode !== row) row.appendChild(form);
          syncPrice();
        } else {
          if (placeholder.parentNode && form.parentNode !== placeholder.parentNode) {
            placeholder.parentNode.insertBefore(form, placeholder);
          }
          /* Desktop: Adet'i form buton satırına al → [Adet][Sepete ekle] aynı satır */
          var btns = form.querySelector('.product-form__buttons');
          if (qty && btns) {
            if (qty.parentNode !== btns) { btns.insertBefore(qty, btns.firstChild); }
            btns.classList.add('eh-buy-row');
          } else if (qty && qtyPlaceholder && qtyPlaceholder.parentNode && qty.parentNode !== qtyPlaceholder.parentNode) {
            qtyPlaceholder.parentNode.insertBefore(qty, qtyPlaceholder);
          }
        }
      }
      place();
      if (mq.addEventListener) mq.addEventListener('change', place);
      else if (mq.addListener) mq.addListener(place);
    }

    function init() { initReadMore(); initStickyBar(); }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

