{% comment %} Muybieno — Abonelik sayfası bespoke bölümü (Nasıl çalışır + avantajlar) {% endcomment %}
{%- style -%}
  #shopify-section-{{ section.id }} .eh-sub { max-width: 110rem; margin: 0 auto; padding: {{ section.settings.padding_top }}px 2.4rem {{ section.settings.padding_bottom }}px; font-family: "Inter", system-ui, sans-serif; }
  #shopify-section-{{ section.id }} .eh-sub__head { text-align: center; max-width: 64rem; margin: 0 auto 4rem; }
  #shopify-section-{{ section.id }} .eh-sub__badge {
    display: inline-flex; align-items: center; gap: 0.7rem; padding: 0.7rem 1.4rem; border-radius: 999px;
    background: rgba(255,255,255,0.6); border: 1px solid rgba(255,255,255,0.75);
    font-size: 1.2rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #A0662F;
  }
  #shopify-section-{{ section.id }} .eh-sub__title {
    font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 600;
    font-size: 4.2rem; line-height: 1.08; color: #2A1B0E; margin: 1.6rem 0 0;
  }
  #shopify-section-{{ section.id }} .eh-sub__lead { font-size: 1.6rem; line-height: 1.6; color: #6E5947; margin: 1.4rem 0 0; }

  #shopify-section-{{ section.id }} .eh-sub__steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.6rem; }
  #shopify-section-{{ section.id }} .eh-sub__step {
    position: relative; padding: 2.4rem 2rem; border-radius: 2rem;
    background: rgba(255,252,247,0.62); -webkit-backdrop-filter: blur(18px); backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.72); box-shadow: 0 16px 38px rgba(74,44,23,0.07);
  }
  #shopify-section-{{ section.id }} .eh-sub__num {
    display: inline-flex; align-items: center; justify-content: center; width: 3.4rem; height: 3.4rem; border-radius: 1rem;
    background: linear-gradient(135deg,#5C3A1E,#8A5A2E); color: #FBF3E7;
    font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 700; font-size: 1.7rem;
  }
  #shopify-section-{{ section.id }} .eh-sub__step h3 { font-size: 1.8rem; font-weight: 700; color: #2A1B0E; margin: 1.4rem 0 0.6rem; }
  #shopify-section-{{ section.id }} .eh-sub__step p { font-size: 1.4rem; line-height: 1.55; color: #6E5947; margin: 0; }

  #shopify-section-{{ section.id }} .eh-sub__perks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; margin-top: 1.6rem; }
  #shopify-section-{{ section.id }} .eh-sub__perk {
    display: flex; align-items: center; gap: 1.1rem; padding: 1.6rem 1.8rem; border-radius: 1.6rem;
    background: rgba(255,252,247,0.55); border: 1px solid rgba(255,255,255,0.7); box-shadow: 0 12px 30px rgba(74,44,23,0.05);
  }
  #shopify-section-{{ section.id }} .eh-sub__perk-ico { flex: none; width: 4rem; height: 4rem; border-radius: 1.2rem; background: linear-gradient(135deg,#5C3A1E,#8A5A2E); display: flex; align-items: center; justify-content: center; }
  #shopify-section-{{ section.id }} .eh-sub__perk-ico svg { width: 2rem; height: 2rem; color: #FBF3E7; }
  #shopify-section-{{ section.id }} .eh-sub__perk b { display: block; font-size: 1.45rem; color: #2A1B0E; }
  #shopify-section-{{ section.id }} .eh-sub__perk span { font-size: 1.25rem; color: #8A7560; }

  #shopify-section-{{ section.id }} .eh-sub__cta { text-align: center; margin-top: 4rem; }
  #shopify-section-{{ section.id }} .eh-sub__btn {
    display: inline-flex; align-items: center; gap: 0.8rem; height: 5.4rem; padding: 0 3rem; border-radius: 1.4rem;
    background: linear-gradient(135deg,#5C3A1E 0%,#8A5A2E 55%,#B07A45 100%); color: #FBF3E7; text-decoration: none;
    font-size: 1.6rem; font-weight: 700; box-shadow: 0 18px 34px rgba(124,80,40,0.28); transition: filter .2s, transform .2s;
  }
  #shopify-section-{{ section.id }} .eh-sub__btn:hover { filter: brightness(1.06); transform: translateY(-2px); }
  #shopify-section-{{ section.id }} .eh-sub__note { font-size: 1.25rem; color: #9C8773; margin-top: 1.4rem; }
  #shopify-section-{{ section.id }} .eh-sub__sectitle { font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 600; font-size: 2.6rem; color: #2A1B0E; text-align: center; margin: 5rem 0 2rem; }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .eh-sub__title { font-size: 3rem; }
    #shopify-section-{{ section.id }} .eh-sub__steps,
    #shopify-section-{{ section.id }} .eh-sub__perks { grid-template-columns: 1fr; }
  }
{%- endstyle -%}

{%- liquid assign s = section.settings -%}
<section class="eh-sub">
  <div class="eh-sub__head">
    {%- if s.badge != blank -%}<div class="eh-sub__badge">{{ s.badge }}</div>{%- endif -%}
    <h1 class="eh-sub__title">{{ s.heading }}</h1>
    {%- if s.lead != blank -%}<p class="eh-sub__lead">{{ s.lead }}</p>{%- endif -%}
  </div>

  <h2 class="eh-sub__sectitle">{{ s.steps_title }}</h2>
  <div class="eh-sub__steps">
    <div class="eh-sub__step"><span class="eh-sub__num">1</span><h3>{{ s.step1_title }}</h3><p>{{ s.step1_text }}</p></div>
    <div class="eh-sub__step"><span class="eh-sub__num">2</span><h3>{{ s.step2_title }}</h3><p>{{ s.step2_text }}</p></div>
    <div class="eh-sub__step"><span class="eh-sub__num">3</span><h3>{{ s.step3_title }}</h3><p>{{ s.step3_text }}</p></div>
  </div>

  <h2 class="eh-sub__sectitle">{{ s.perks_title }}</h2>
  <div class="eh-sub__perks">
    <div class="eh-sub__perk">
      <span class="eh-sub__perk-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg></span>
      <div><b>{{ s.perk1_title }}</b><span>{{ s.perk1_text }}</span></div>
    </div>
    <div class="eh-sub__perk">
      <span class="eh-sub__perk-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></span>
      <div><b>{{ s.perk2_title }}</b><span>{{ s.perk2_text }}</span></div>
    </div>
    <div class="eh-sub__perk">
      <span class="eh-sub__perk-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg></span>
      <div><b>{{ s.perk3_title }}</b><span>{{ s.perk3_text }}</span></div>
    </div>
  </div>

  {%- if s.button_label != blank -%}
    <div class="eh-sub__cta">
      <a class="eh-sub__btn" href="{{ s.button_link | default: '/collections/all' }}">{{ s.button_label }}</a>
      {%- if s.note != blank -%}<div class="eh-sub__note">{{ s.note }}</div>{%- endif -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Muybieno Abonelik",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "badge", "label": "Rozet", "default": "Kahve Aboneliği" },
    { "type": "text", "id": "heading", "label": "Başlık", "default": "Kahveniz hiç bitmesin" },
    { "type": "textarea", "id": "lead", "label": "Açıklama", "default": "Her ay taze kavrulmuş çekirdekler kapınızda — abonelere özel %10 indirim ve ücretsiz kargo. Dilediğiniz zaman duraklatın veya iptal edin." },
    { "type": "text", "id": "steps_title", "label": "Adımlar başlığı", "default": "Nasıl çalışır?" },
    { "type": "text", "id": "step1_title", "default": "Kahveni seç", "label": "Adım 1 başlık" },
    { "type": "textarea", "id": "step1_text", "default": "Tek origin çekirdek, öğütülmüş filtre ya da Türk kahvesi — damak zevkine göre.", "label": "Adım 1 metin" },
    { "type": "text", "id": "step2_title", "default": "Sıklığı belirle", "label": "Adım 2 başlık" },
    { "type": "textarea", "id": "step2_text", "default": "2, 4 veya 6 haftada bir teslimat. Tüketimine göre ayarla.", "label": "Adım 2 metin" },
    { "type": "text", "id": "step3_title", "default": "Rahatına bak", "label": "Adım 3 başlık" },
    { "type": "textarea", "id": "step3_text", "default": "Taze kavrum, otomatik teslimat. İstediğin zaman duraklat veya iptal et.", "label": "Adım 3 metin" },
    { "type": "text", "id": "perks_title", "label": "Avantajlar başlığı", "default": "Abonelik avantajları" },
    { "type": "text", "id": "perk1_title", "default": "%10 indirim", "label": "Avantaj 1 başlık" },
    { "type": "text", "id": "perk1_text", "default": "Her teslimatta", "label": "Avantaj 1 metin" },
    { "type": "text", "id": "perk2_title", "default": "Taze kavrum", "label": "Avantaj 2 başlık" },
    { "type": "text", "id": "perk2_text", "default": "Kavrumdan teslime 48 saat", "label": "Avantaj 2 metin" },
    { "type": "text", "id": "perk3_title", "default": "Esnek", "label": "Avantaj 3 başlık" },
    { "type": "text", "id": "perk3_text", "default": "Duraklat, değiştir, iptal et", "label": "Avantaj 3 metin" },
    { "type": "text", "id": "button_label", "label": "Buton", "default": "Kahveleri keşfet" },
    { "type": "url", "id": "button_link", "label": "Buton linki" },
    { "type": "text", "id": "note", "label": "Buton altı not", "default": "Abonelik seçeneği ürün sayfasında görünür." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Üst boşluk", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Alt boşluk", "default": 64 }
  ],
  "presets": [ { "name": "Muybieno Abonelik" } ]
}
{% endschema %}
