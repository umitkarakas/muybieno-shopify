{% comment %}
  Muybieno — header altı kategori barı (kahve.com / Moliendo tarzı görsel kartlar).
  KENDİ İÇİNDE TANIMLI: kategoriler aşağıdaki listede sabit; görsel + link doğrudan
  collections[handle]'dan gelir (koleksiyon görseli yoksa ilk ürün görseli).
  Neden blok değil: JSON template'e 'collection' bloğu ayarı GitHub sync'te düşüyordu
  (şema/divergence tuzağı). .liquid içinde sabit liste güvenilir şekilde render eder.
  Sıra/kategori değiştirmek için aşağıdaki 'cats' listesini düzenleyin: handle|etiket|ikon
{% endcomment %}

{%- liquid
  comment
    Liste: handle|etiket|görsel(asset). Görseller assets/ içindeki cat-*.png dosyaları.
  endcomment
  assign cats = 'cekirdek-kahveler|Çekirdek Kahve|cat-cekirdek.png,ogutulmus-filtre-kahveler|Öğütülmüş Filtre|cat-ogutulmus.png,turk-kahvesi|Türk Kahvesi|cat-turk.png,kapsul-kahveler|Kapsül Kahve|cat-kapsul.png,pratik-hazir-kahveler|Kolay Kahve|cat-kolay.png,kiloluk-kahveler|Kiloluk Kahve|cat-kiloluk.png,ekipmanlar|Ekipman|cat-ekipman.png' | split: ','
  assign cat_count = cats.size
-%}

<div class="eh-catbar color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="eh-catbar__title">{{ section.settings.heading }}</p>
    {%- endif -%}
    <ul class="eh-catbar__list">
      {%- for c in cats -%}
        {%- liquid
          assign parts = c | split: '|'
          assign handle = parts[0]
          assign label = parts[1]
          assign asset = parts[2]
          assign col = collections[handle]
          assign url = col.url | default: '#'
        -%}
        <li class="eh-catbar__item">
          <a class="eh-catbar__link" href="{{ url }}">
            <span class="eh-catbar__card">
              <img src="{{ asset | asset_url }}" class="eh-catbar__img" alt="{{ label | escape }}" loading="lazy" width="440" height="440">
            </span>
            <span class="eh-catbar__label">{{ label | escape }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .eh-catbar {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .eh-catbar__title {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.2rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: #9C8773; margin: 0 0 1.6rem; text-align: center;
  }
  #shopify-section-{{ section.id }} .eh-catbar__list {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat({{ cat_count }}, minmax(0, 1fr));
    gap: 1.4rem;
  }
  #shopify-section-{{ section.id }} .eh-catbar__item { min-width: 0; }
  #shopify-section-{{ section.id }} .eh-catbar__link {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .eh-catbar__card {
    width: 100%; aspect-ratio: 1 / 1;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    border-radius: 1.8rem;
    background: linear-gradient(160deg, rgba(176,122,69,0.14), rgba(138,90,46,0.08));
    border: 1px solid rgba(255,255,255,0.7);
    box-shadow: 0 14px 32px rgba(74,44,23,0.07);
    transition: transform .2s ease, box-shadow .2s ease;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .eh-catbar__link:hover .eh-catbar__card {
    transform: translateY(-4px);
    box-shadow: 0 22px 44px rgba(74,44,23,0.13);
  }
  #shopify-section-{{ section.id }} .eh-catbar__img {
    width: 100%; height: 100%; object-fit: contain; object-position: center;
    filter: drop-shadow(0 8px 14px rgba(58,34,15,0.18));
  }
  #shopify-section-{{ section.id }} .eh-catbar__ph {
    width: 46%; height: 46%; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg,#5C3A1E,#8A5A2E); color: #FBF3E7;
  }
  #shopify-section-{{ section.id }} .eh-catbar__ph svg { width: 50%; height: 50%; }
  #shopify-section-{{ section.id }} .eh-catbar__label {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.45rem; font-weight: 600; line-height: 1.25; color: #2A1B0E;
    text-align: center;
  }

  /* Mobil: yatay kaydırılabilir scroll-snap */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .eh-catbar__list {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 30%;
      overflow-x: auto; scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
      margin-inline: -1.5rem; padding-inline: 1.5rem;
    }
    #shopify-section-{{ section.id }} .eh-catbar__list::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .eh-catbar__item { scroll-snap-align: start; }
    #shopify-section-{{ section.id }} .eh-catbar__label { font-size: 1.3rem; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Muybieno kategori barı",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Header altında görsel kartlı kategori barı. Kategoriler section dosyasındaki sabit listeden gelir; görseller koleksiyon/ilk ürün fotoğrafından otomatik. Kategori eklemek/çıkarmak için sections/eh-category-bar.liquid içindeki 'cats' listesini düzenleyin." },
    { "type": "text", "id": "heading", "label": "Üst başlık (opsiyonel)" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması", "default": "background-1" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 12 }
  ],
  "presets": [
    { "name": "Muybieno kategori barı" }
  ]
}
{% endschema %}

