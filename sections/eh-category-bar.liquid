{% comment %}
  Muybieno — header altı kategori barı (kahve.com / Moliendo tarzı görsel kartlar).
  Her blok bir koleksiyona bağlanır; kartta ürün/koleksiyon görseli, altında kategori adı.
  Görsel sırası: blok görseli > koleksiyon görseli > koleksiyonun ilk ürün görseli.
  Masaüstünde tek sıra (auto-fit), mobilde yatay scroll-snap.
{% endcomment %}

<div class="eh-catbar color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="eh-catbar__title">{{ section.settings.heading }}</p>
    {%- endif -%}
    <ul class="eh-catbar__list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign img = block.settings.image
          if img == blank and col != blank
            if col.image != blank
              assign img = col.image
            elsif col.featured_image != blank
              assign img = col.featured_image
            elsif col.products.first != blank
              assign img = col.products.first.featured_image
            endif
          endif
          assign label = block.settings.label
          if label == blank and col != blank
            assign label = col.title
          endif
          assign url = block.settings.link
          if url == blank and col != blank
            assign url = col.url
          endif
          assign url = url | default: '#'
        -%}
        <li class="eh-catbar__item" {{ block.shopify_attributes }}>
          <a class="eh-catbar__link" href="{{ url }}">
            <span class="eh-catbar__card">
              {%- if img != blank -%}
                {{ img | image_url: width: 440 | image_tag: loading: 'lazy', class: 'eh-catbar__img', alt: label, widths: '220,330,440' }}
              {%- else -%}
                <span class="eh-catbar__ph">{% render 'eh-cat-icon', icon: block.settings.icon %}</span>
              {%- endif -%}
            </span>
            <span class="eh-catbar__label">{{ label | escape }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .eh-catbar {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .eh-catbar__title {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.2rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: #9C8773; margin: 0 0 1.6rem; text-align: center;
  }
  #shopify-section-{{ section.id }} .eh-catbar__list {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, minmax(0, 1fr));
    gap: 1.4rem;
  }
  #shopify-section-{{ section.id }} .eh-catbar__item { min-width: 0; }
  #shopify-section-{{ section.id }} .eh-catbar__link {
    display: flex; flex-direction: column; align-items: center; gap: 1rem;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .eh-catbar__card {
    width: 100%; aspect-ratio: 1 / 1;
    display: flex; align-items: center; justify-content: center;
    padding: 14%;
    border-radius: 1.8rem;
    background: linear-gradient(160deg, rgba(176,122,69,0.14), rgba(138,90,46,0.08));
    border: 1px solid rgba(255,255,255,0.7);
    box-shadow: 0 14px 32px rgba(74,44,23,0.07);
    transition: transform .2s ease, box-shadow .2s ease;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .eh-catbar__link:hover .eh-catbar__card {
    transform: translateY(-4px);
    box-shadow: 0 22px 44px rgba(74,44,23,0.13);
  }
  #shopify-section-{{ section.id }} .eh-catbar__img {
    width: 100%; height: 100%; object-fit: contain;
    filter: drop-shadow(0 8px 14px rgba(58,34,15,0.18));
  }
  #shopify-section-{{ section.id }} .eh-catbar__ph {
    width: 46%; height: 46%; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg,#5C3A1E,#8A5A2E); color: #FBF3E7;
  }
  #shopify-section-{{ section.id }} .eh-catbar__ph svg { width: 50%; height: 50%; }
  #shopify-section-{{ section.id }} .eh-catbar__label {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 1.45rem; font-weight: 600; line-height: 1.25; color: #2A1B0E;
    text-align: center;
  }

  /* Mobil: yatay kaydırılabilir scroll-snap */
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .eh-catbar__list {
      grid-template-columns: none;
      grid-auto-flow: column;
      grid-auto-columns: 30%;
      overflow-x: auto; scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
      margin-inline: -1.5rem; padding-inline: 1.5rem;
    }
    #shopify-section-{{ section.id }} .eh-catbar__list::-webkit-scrollbar { display: none; }
    #shopify-section-{{ section.id }} .eh-catbar__item { scroll-snap-align: start; }
    #shopify-section-{{ section.id }} .eh-catbar__label { font-size: 1.3rem; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Muybieno kategori barı",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Header altında görsel kartlı kategori barı. Her blok bir koleksiyona bağlanır; görsel otomatik koleksiyondan/ilk üründen gelir (blok görseliyle değiştirilebilir). Masaüstünde tek sıra, mobilde yatay kaydırılır." },
    { "type": "text", "id": "heading", "label": "Üst başlık (opsiyonel)", "default": "" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması", "default": "background-1" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 12 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategori",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Koleksiyon" },
        { "type": "text", "id": "label", "label": "Etiket (boşsa koleksiyon adı)" },
        { "type": "image_picker", "id": "image", "label": "Görsel (boşsa koleksiyon/ürün görseli)" },
        { "type": "url", "id": "link", "label": "Bağlantı (boşsa koleksiyon linki)" },
        { "type": "select", "id": "icon", "label": "Yedek ikon (görsel yoksa)", "default": "coffee",
          "options": [
            {"value":"coffee","label":"Kahve"},{"value":"filter","label":"Filtre"},{"value":"droplet","label":"Damla"},{"value":"capsule","label":"Kapsül"},{"value":"zap","label":"Pratik"},{"value":"box","label":"Kutu"},{"value":"cup","label":"Fincan"},{"value":"file","label":"Kağıt filtre"},{"value":"beaker","label":"French press"},{"value":"thermos","label":"Termos"},{"value":"gift","label":"Hediye"}
          ] }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Muybieno kategori barı",
      "blocks": [
        { "type": "category", "settings": { "label": "Çekirdek", "icon": "coffee" } },
        { "type": "category", "settings": { "label": "Öğütülmüş Filtre", "icon": "filter" } },
        { "type": "category", "settings": { "label": "Türk Kahvesi", "icon": "cup" } },
        { "type": "category", "settings": { "label": "Kapsül", "icon": "capsule" } },
        { "type": "category", "settings": { "label": "Pratik & Hazır", "icon": "zap" } },
        { "type": "category", "settings": { "label": "Kiloluk", "icon": "box" } },
        { "type": "category", "settings": { "label": "French Press", "icon": "beaker" } },
        { "type": "category", "settings": { "label": "Hediye Setleri", "icon": "gift" } }
      ]
    }
  ]
}
{% endschema %}
