{% comment %}
  Muybieno — sekmeli ürün carousel'i (kahve.com tarzı).
  Üstte sekmeler; sekmeye tıklayınca o koleksiyonun ürünleri carousel'de gösterilir.
  KENDİ İÇİNDE TANIMLI: sekmeler aşağıdaki 'tabs' listesinde sabit (handle|etiket).
  JSON template sync tuzağına takılmamak için blok yerine sabit liste. Kartlar tema card-product.
  Sekme eklemek/değiştirmek: 'tabs' listesini düzenleyin.
{% endcomment %}

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign tabs = 'all|Tüm Ürünler,cekirdek-kahveler|Çekirdek Kahveler,ogutulmus-filtre-kahveler|Filtre Kahveler,turk-kahvesi|Türk Kahvesi,demleme-ekipmanlari|Ekipmanlar' | split: ','
-%}

<div class="eh-tabcar page-width color-{{ section.settings.color_scheme }}" id="EhTabcar-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="eh-tabcar__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="eh-tabcar__tabs" role="tablist">
    {%- for t in tabs -%}
      {%- assign parts = t | split: '|' -%}
      <button type="button" class="eh-tabcar__tab{% if forloop.first %} is-active{% endif %}" data-eh-tab="{{ forloop.index0 }}" role="tab">{{ parts[1] }}</button>
    {%- endfor -%}
  </div>

  <div class="eh-tabcar__panels">
    {%- for t in tabs -%}
      {%- assign parts = t | split: '|' -%}
      {%- assign col = collections[parts[0]] -%}
      <div class="eh-tabcar__panel{% if forloop.first %} is-active{% endif %}" data-eh-panel="{{ forloop.index0 }}">
        {%- if col != blank and col.products.size > 0 -%}
          <button type="button" class="eh-tabcar__nav eh-tabcar__nav--prev" aria-label="Önceki">{{- '' -}}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <ul class="eh-tabcar__row" role="list">
            {%- for product in col.products limit: 12 -%}
              <li class="eh-tabcar__item">
                {% render 'card-product',
                  card_product: product,
                  media_aspect_ratio: 'portrait',
                  show_secondary_image: true,
                  show_vendor: false,
                  show_rating: false,
                  section_id: section.id,
                  quick_add: 'standard'
                %}
              </li>
            {%- endfor -%}
          </ul>
          <button type="button" class="eh-tabcar__nav eh-tabcar__nav--next" aria-label="Sonraki">{{- '' -}}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        {%- else -%}
          <p class="eh-tabcar__empty">Bu kategoride ürün bulunamadı.</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .eh-tabcar { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  #shopify-section-{{ section.id }} .eh-tabcar__heading {
    font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 600; font-size: 3.4rem;
    line-height: 1.1; margin: 0 0 2rem; color: #2A1B0E;
  }
  #shopify-section-{{ section.id }} .eh-tabcar__tabs {
    display: flex; gap: 0.8rem; flex-wrap: wrap; margin-bottom: 2.2rem;
  }
  #shopify-section-{{ section.id }} .eh-tabcar__tab {
    appearance: none; cursor: pointer; flex: none;
    font-family: "Inter", system-ui, sans-serif; font-size: 1.45rem; font-weight: 600;
    color: #5C3A1E; padding: 1rem 1.8rem; border-radius: 999px;
    background: rgba(255,252,247,0.7); border: 1px solid rgba(92,58,30,0.16);
    transition: color .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
  }
  #shopify-section-{{ section.id }} .eh-tabcar__tab:hover { border-color: #8A5A2E; }
  #shopify-section-{{ section.id }} .eh-tabcar__tab.is-active {
    color: #FBF3E7; font-weight: 700; border-color: transparent;
    background: linear-gradient(135deg,#5C3A1E,#8A5A2E); box-shadow: 0 8px 18px rgba(124,80,40,0.22);
  }
  #shopify-section-{{ section.id }} .eh-tabcar__panel { display: none; position: relative; }
  #shopify-section-{{ section.id }} .eh-tabcar__panel.is-active { display: block; }
  #shopify-section-{{ section.id }} .eh-tabcar__row {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-auto-flow: column; grid-auto-columns: calc((100% - 3 * 1.6rem) / 4);
    gap: 1.6rem; overflow-x: auto; scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch; scrollbar-width: none; scroll-behavior: smooth;
  }
  #shopify-section-{{ section.id }} .eh-tabcar__row::-webkit-scrollbar { display: none; }
  #shopify-section-{{ section.id }} .eh-tabcar__item { scroll-snap-align: start; min-width: 0; }
  /* Carousel ok butonları (masaüstü) */
  #shopify-section-{{ section.id }} .eh-tabcar__nav {
    position: absolute; top: 38%; transform: translateY(-50%); z-index: 2;
    width: 4.4rem; height: 4.4rem; border-radius: 50%; cursor: pointer;
    background: #FFFCF7; border: 1px solid rgba(92,58,30,0.16);
    box-shadow: 0 10px 24px rgba(74,44,23,0.12); color: #5C3A1E;
    display: none; align-items: center; justify-content: center;
  }
  #shopify-section-{{ section.id }} .eh-tabcar__nav svg { width: 2rem; height: 2rem; }
  #shopify-section-{{ section.id }} .eh-tabcar__nav--prev { left: -2.2rem; }
  #shopify-section-{{ section.id }} .eh-tabcar__nav--next { right: -2.2rem; }
  #shopify-section-{{ section.id }} .eh-tabcar__empty { color: #8A7560; font-family: "Inter", system-ui, sans-serif; }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .eh-tabcar__nav { display: flex; }
  }
  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .eh-tabcar__row { grid-auto-columns: 44%; }
  }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .eh-tabcar__heading { font-size: 2.8rem; }
    #shopify-section-{{ section.id }} .eh-tabcar__row { grid-auto-columns: 62%; }
    #shopify-section-{{ section.id }} .eh-tabcar__tabs { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; margin-inline: -1.5rem; padding-inline: 1.5rem; }
    #shopify-section-{{ section.id }} .eh-tabcar__tabs::-webkit-scrollbar { display: none; }
  }
{%- endstyle -%}

<script>
  (function () {
    var root = document.getElementById('EhTabcar-{{ section.id }}');
    if (!root || root.dataset.ehInit) return;
    root.dataset.ehInit = '1';
    var tabs = [].slice.call(root.querySelectorAll('.eh-tabcar__tab'));
    var panels = [].slice.call(root.querySelectorAll('.eh-tabcar__panel'));
    tabs.forEach(function (t) {
      t.addEventListener('click', function () {
        var k = t.getAttribute('data-eh-tab');
        tabs.forEach(function (x) { x.classList.toggle('is-active', x === t); });
        panels.forEach(function (p) { p.classList.toggle('is-active', p.getAttribute('data-eh-panel') === k); });
      });
    });
    /* Ok butonları */
    root.addEventListener('click', function (e) {
      var btn = e.target.closest('.eh-tabcar__nav');
      if (!btn) return;
      var panel = btn.closest('.eh-tabcar__panel');
      var row = panel && panel.querySelector('.eh-tabcar__row');
      if (!row) return;
      var amount = row.clientWidth * 0.8;
      row.scrollBy({ left: btn.classList.contains('eh-tabcar__nav--prev') ? -amount : amount, behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "Muybieno sekmeli carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "paragraph", "content": "Sekmeli ürün carousel'i. Sekmeler section dosyasındaki sabit 'tabs' listesinden gelir (handle|etiket). Kartlar tema ürün kartını kullanır." },
    { "type": "text", "id": "heading", "label": "Başlık (opsiyonel)" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması", "default": "background-1" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36 }
  ],
  "presets": [ { "name": "Muybieno sekmeli carousel" } ]
}
{% endschema %}
