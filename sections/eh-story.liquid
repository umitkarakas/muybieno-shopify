{% comment %} Muybieno — hikaye bölümü (espresso görsel kart + metin + noktalar). {% endcomment %}
{%- style -%}
  #shopify-section-{{ section.id }} .eh-story { max-width: 128rem; margin: 0 auto; padding: {{ section.settings.padding_top }}px 2.4rem {{ section.settings.padding_bottom }}px; font-family: "Inter", system-ui, sans-serif; }
  #shopify-section-{{ section.id }} .eh-story__grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 4rem; align-items: center; }
  #shopify-section-{{ section.id }} .eh-story__visual {
    position: relative; aspect-ratio: 5/4; border-radius: 2.4rem; overflow: hidden;
    background: radial-gradient(circle at 30% 30%, #A86A38, #4A2C17 75%);
    border: 1px solid rgba(255,255,255,0.45); box-shadow: 0 26px 60px rgba(58,34,15,0.26);
    display: flex; align-items: center; justify-content: center;
  }
  #shopify-section-{{ section.id }} .eh-story__visual img { width: 100%; height: 100%; object-fit: cover; }
  #shopify-section-{{ section.id }} .eh-story__ico { width: 7.8rem; height: 7.8rem; color: rgba(251,243,231,0.28); }
  #shopify-section-{{ section.id }} .eh-story__ph { position: absolute; bottom: 1.4rem; font-size: 1.05rem; color: rgba(251,243,231,0.62); font-family: ui-monospace, monospace; }
  #shopify-section-{{ section.id }} .eh-story__eyebrow { font-size: 1.2rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #A0662F; }
  #shopify-section-{{ section.id }} .eh-story__title { font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 600; font-size: 3.8rem; line-height: 1.12; margin: 0.8rem 0 0; color: #2A1B0E; }
  #shopify-section-{{ section.id }} .eh-story__text { font-size: 1.55rem; line-height: 1.65; color: #6E5947; margin: 1.6rem 0 0; font-weight: 500; }
  #shopify-section-{{ section.id }} .eh-story__points { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; margin-top: 2.4rem; }
  #shopify-section-{{ section.id }} .eh-story__point { display: flex; align-items: flex-start; gap: 1.1rem; }
  #shopify-section-{{ section.id }} .eh-story__point-ico { flex: none; width: 2rem; height: 2rem; margin-top: 0.1rem; color: #5C3A1E; }
  #shopify-section-{{ section.id }} .eh-story__point-ico svg { width: 2rem; height: 2rem; }
  #shopify-section-{{ section.id }} .eh-story__point b { display: block; font-size: 1.45rem; font-weight: 700; color: #2A1B0E; }
  #shopify-section-{{ section.id }} .eh-story__point span { font-size: 1.25rem; color: #8A7560; font-weight: 500; line-height: 1.45; }
  #shopify-section-{{ section.id }} .eh-story__cta {
    display: inline-flex; align-items: center; gap: 0.8rem; margin-top: 2.6rem; height: 5rem; padding: 0 2.6rem; border-radius: 1.4rem;
    background: linear-gradient(135deg,#5C3A1E 0%,#8A5A2E 55%,#B07A45 100%); color: #FBF3E7; text-decoration: none;
    font-size: 1.5rem; font-weight: 700; box-shadow: 0 18px 34px rgba(124,80,40,0.28); transition: filter .2s, transform .2s;
  }
  #shopify-section-{{ section.id }} .eh-story__cta:hover { filter: brightness(1.06); transform: translateY(-2px); }
  @media screen and (max-width: 860px) {
    #shopify-section-{{ section.id }} .eh-story__grid { grid-template-columns: 1fr; gap: 2.8rem; }
    #shopify-section-{{ section.id }} .eh-story__title { font-size: 3rem; }
  }
  @media screen and (max-width: 480px) { #shopify-section-{{ section.id }} .eh-story__points { grid-template-columns: 1fr; } }
{%- endstyle -%}

{%- liquid assign s = section.settings -%}
<section class="eh-story">
  <div class="eh-story__grid">
    <div class="eh-story__visual">
      {%- if s.image != blank -%}
        {{ s.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: s.heading, sizes: '(max-width: 860px) 90vw, 45vw', widths: '400,600,900,1200' }}
      {%- else -%}
        <svg class="eh-story__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3q1 4 4 6.5t3 5.5a1 1 0 0 1-14 0 5 5 0 0 1 1-3 1 1 0 0 0 5 0c0-2-1.5-3-1.5-5q0-2 2.5-4"/></svg>
        {%- if s.placeholder_label != blank -%}<span class="eh-story__ph">{{ s.placeholder_label }}</span>{%- endif -%}
      {%- endif -%}
    </div>
    <div class="eh-story__copy">
      {%- if s.eyebrow != blank -%}<div class="eh-story__eyebrow">{{ s.eyebrow }}</div>{%- endif -%}
      {%- if s.heading != blank -%}<h2 class="eh-story__title">{{ s.heading }}</h2>{%- endif -%}
      {%- if s.text != blank -%}<p class="eh-story__text">{{ s.text }}</p>{%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <div class="eh-story__points">
          {%- for block in section.blocks -%}
            <div class="eh-story__point" {{ block.shopify_attributes }}>
              <span class="eh-story__point-ico">{% render 'eh-cat-icon', icon: block.settings.icon %}</span>
              <div><b>{{ block.settings.title }}</b><span>{{ block.settings.sub }}</span></div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
      {%- if s.button_label != blank -%}
        <a class="eh-story__cta" href="{{ s.button_link | default: '#' }}">{{ s.button_label }}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Muybieno Hikaye",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Üst etiket", "default": "Hikayemiz" },
    { "type": "text", "id": "heading", "label": "Başlık", "default": "Çekirdekten fincana, ustalıkla" },
    { "type": "textarea", "id": "text", "label": "Metin", "default": "Muybieno, kahveyi bir ritüel olarak görenler için kuruldu. Üreticiyle doğrudan çalışır, küçük partiler hâlinde kavururuz. Amacımız basit: her fincanda bölgenin karakterini taze ve dürüst biçimde sunmak." },
    { "type": "image_picker", "id": "image", "label": "Görsel", "info": "Boş bırakılırsa espresso gradyan + ikon gösterilir." },
    { "type": "text", "id": "placeholder_label", "label": "Görselsiz placeholder etiketi", "default": "kavurma atölyesi fotoğrafı" },
    { "type": "text", "id": "button_label", "label": "Buton", "default": "Hikayemiz" },
    { "type": "url", "id": "button_link", "label": "Buton linki" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Üst boşluk", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Alt boşluk", "default": 40 }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Hikaye noktası",
      "settings": [
        { "type": "select", "id": "icon", "label": "İkon", "default": "coffee", "options": [
          { "value": "coffee", "label": "Kahve" }, { "value": "droplet", "label": "Damla" }, { "value": "filter", "label": "Filtre" },
          { "value": "box", "label": "Kutu" }, { "value": "zap", "label": "Şimşek" }, { "value": "gift", "label": "Hediye" }, { "value": "beaker", "label": "Demlik" }
        ] },
        { "type": "text", "id": "title", "label": "Başlık", "default": "Tek origin" },
        { "type": "text", "id": "sub", "label": "Alt metin", "default": "Üreticiden doğrudan, izlenebilir." }
      ]
    }
  ],
  "presets": [ { "name": "Muybieno Hikaye", "blocks": [ { "type": "point" }, { "type": "point" }, { "type": "point" }, { "type": "point" } ] } ]
}
{% endschema %}
