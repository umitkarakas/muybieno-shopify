{% comment %}
  Muybieno — ana sayfa "Kahveye Dair" blog bölümü.
  Seçilen blogun son yazılarını camsı krem kartlarda gösterir (kapak + tarih + başlık + özet).
  Kendi içinde tanımlı; tema card stilinden bağımsız. Preset'li → editörden eklenebilir.
{% endcomment %}

{%- liquid
  assign blg = blogs[section.settings.blog]
-%}

<div class="eh-blog page-width color-{{ section.settings.color_scheme }}" id="EhBlog-{{ section.id }}">
  <div class="eh-blog__head">
    <div>
      {%- if section.settings.eyebrow != blank -%}<p class="eh-blog__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="eh-blog__heading">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    {%- if section.settings.link_label != blank and blg != blank -%}
      <a class="eh-blog__viewall" href="{{ blg.url }}">{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>

  {%- if blg != blank and blg.articles_count > 0 -%}
    <div class="eh-blog__grid">
      {%- for article in blg.articles limit: section.settings.post_limit -%}
        <a class="eh-blog__card" href="{{ article.url }}">
          <div class="eh-blog__media">
            {%- if article.image != blank -%}
              {{ article.image | image_url: width: 700 | image_tag: loading: 'lazy', widths: '300,500,700', sizes: '(max-width:749px) 90vw, 33vw', alt: article.title | escape }}
            {%- else -%}
              <div class="eh-blog__media-ph" aria-hidden="true"></div>
            {%- endif -%}
          </div>
          <div class="eh-blog__body">
            <p class="eh-blog__date">{{ article.published_at | date: '%d.%m.%Y' }}</p>
            <h3 class="eh-blog__title">{{ article.title }}</h3>
            {%- if article.excerpt_or_content != blank -%}
              <p class="eh-blog__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 22 }}</p>
            {%- endif -%}
            <span class="eh-blog__more">Devamını oku →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="eh-blog__empty">Gösterilecek yazı bulunamadı. Bölüm ayarlarından bir blog seçin.</p>
  {%- endif -%}
</div>

{%- style -%}
  #shopify-section-{{ section.id }} .eh-blog { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
  #shopify-section-{{ section.id }} .eh-blog__head { display: flex; align-items: flex-end; justify-content: space-between; gap: 1.6rem; margin: 0 0 2.4rem; }
  #shopify-section-{{ section.id }} .eh-blog__eyebrow { font-family: "Inter", system-ui, sans-serif; font-size: 1.25rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: #8A5A2E; margin: 0 0 .6rem; }
  #shopify-section-{{ section.id }} .eh-blog__heading { font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 700; font-size: 3.4rem; line-height: 1.1; margin: 0; color: #2A1B0E; }
  #shopify-section-{{ section.id }} .eh-blog__viewall { flex: none; font-family: "Inter", system-ui, sans-serif; font-size: 1.4rem; font-weight: 600; color: #5C3A1E; text-decoration: none; padding: .9rem 1.8rem; border-radius: 999px; background: rgba(255,252,247,.7); border: 1px solid rgba(92,58,30,.16); transition: border-color .18s ease; }
  #shopify-section-{{ section.id }} .eh-blog__viewall:hover { border-color: #8A5A2E; }
  #shopify-section-{{ section.id }} .eh-blog__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.4rem; }
  #shopify-section-{{ section.id }} .eh-blog__card { display: flex; flex-direction: column; background: rgba(255,252,247,.62); border: 1px solid rgba(255,255,255,.7); border-radius: 1.8rem; overflow: hidden; text-decoration: none; box-shadow: 0 16px 38px rgba(74,44,23,.07); backdrop-filter: blur(18px); transition: transform .18s ease, box-shadow .18s ease; }
  #shopify-section-{{ section.id }} .eh-blog__card:hover { transform: translateY(-3px); box-shadow: 0 22px 48px rgba(74,44,23,.12); }
  #shopify-section-{{ section.id }} .eh-blog__media { aspect-ratio: 16/10; overflow: hidden; background: #EFE3D2; }
  #shopify-section-{{ section.id }} .eh-blog__media img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .3s ease; }
  #shopify-section-{{ section.id }} .eh-blog__card:hover .eh-blog__media img { transform: scale(1.04); }
  #shopify-section-{{ section.id }} .eh-blog__media-ph { width: 100%; height: 100%; background: linear-gradient(135deg,#5C3A1E,#8A5A2E,#B07A45); }
  #shopify-section-{{ section.id }} .eh-blog__body { padding: 1.8rem 2rem 2.2rem; display: flex; flex-direction: column; flex: 1 1 auto; }
  #shopify-section-{{ section.id }} .eh-blog__date { font-family: "Inter", system-ui, sans-serif; font-size: 1.2rem; color: #9C8773; margin: 0 0 .6rem; }
  #shopify-section-{{ section.id }} .eh-blog__title { font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 600; font-size: 1.9rem; line-height: 1.25; color: #2A1B0E; margin: 0 0 .8rem; }
  #shopify-section-{{ section.id }} .eh-blog__excerpt { font-family: "Inter", system-ui, sans-serif; font-size: 1.4rem; line-height: 1.6; color: #6E5947; margin: 0 0 1.4rem; }
  #shopify-section-{{ section.id }} .eh-blog__more { margin-top: auto; font-family: "Inter", system-ui, sans-serif; font-size: 1.4rem; font-weight: 700; color: #5C3A1E; }
  #shopify-section-{{ section.id }} .eh-blog__empty { color: #8A7560; font-family: "Inter", system-ui, sans-serif; }
  @media screen and (max-width: 989px) { #shopify-section-{{ section.id }} .eh-blog__grid { grid-template-columns: repeat(2, 1fr); } }
  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .eh-blog__grid { grid-template-columns: 1fr; }
    #shopify-section-{{ section.id }} .eh-blog__heading { font-size: 2.8rem; }
    #shopify-section-{{ section.id }} .eh-blog__head { align-items: flex-start; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Muybieno blog (Kahveye Dair)",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Üst etiket", "default": "Blog" },
    { "type": "text", "id": "heading", "label": "Başlık", "default": "Kahveye Dair" },
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "range", "id": "post_limit", "label": "Yazı sayısı", "min": 3, "max": 6, "step": 1, "default": 3 },
    { "type": "text", "id": "link_label", "label": "Bağlantı etiketi", "default": "Tümünü gör" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Renk şeması", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "label": "Üst boşluk", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 48 },
    { "type": "range", "id": "padding_bottom", "label": "Alt boşluk", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [ { "name": "Muybieno blog (Kahveye Dair)", "settings": { "blog": "blog" } } ]
}
{% endschema %}
