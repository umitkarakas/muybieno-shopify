{% comment %}
  Muybieno — SADE hero slider: sol espresso panel (başlık + alt yazı + buton) + sağ görsel.
  Slide'lar 'slide' blokları; blok yoksa section.settings'ten tek slide (geri uyum).
  Crossfade + oklar + noktalar + otomatik geçiş + mobilde kaydırma.
{% endcomment %}
{%- style -%}
  #shopify-section-{{ section.id }} .eh-hero2 { position: relative; max-width: 128rem; margin: 0 auto; padding: 24px 2.4rem 8px; }
  #shopify-section-{{ section.id }} .eh-hero2__frame { position: relative; border-radius: 2rem; overflow: hidden; box-shadow: 0 20px 50px rgba(58,34,15,0.14); }
  #shopify-section-{{ section.id }} .eh-hero2__slides { display: grid; }
  #shopify-section-{{ section.id }} .eh-hero__slide { grid-area: 1 / 1; opacity: 0; visibility: hidden; pointer-events: none; transition: opacity .5s ease; }
  #shopify-section-{{ section.id }} .eh-hero__slide.is-active { opacity: 1; visibility: visible; pointer-events: auto; }

  #shopify-section-{{ section.id }} .eh-hero2__in { display: grid; grid-template-columns: 1fr 1fr; min-height: 42rem; }
  #shopify-section-{{ section.id }} .eh-hero2__text {
    background: linear-gradient(135deg, #5C3A1E 0%, #43280F 100%);
    color: #FBF3E7; padding: 4.5rem 4.5rem; display: flex; flex-direction: column; justify-content: center;
  }
  #shopify-section-{{ section.id }} .eh-hero2__badge {
    align-self: flex-start; display: inline-block; margin: 0 0 1.6rem;
    font-family: "Inter", system-ui, sans-serif; font-size: 1.2rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    color: #E8C9A0; padding: 0.6rem 1.2rem; border: 1px solid rgba(232,201,160,0.4); border-radius: 999px;
  }
  #shopify-section-{{ section.id }} .eh-hero2__title { font-family: "Bricolage Grotesque", system-ui, sans-serif; font-weight: 700; font-size: 4.4rem; line-height: 1.08; color: #FBF3E7; }
  #shopify-section-{{ section.id }} .eh-hero2__title p { margin: 0; }
  #shopify-section-{{ section.id }} .eh-hero2__title em { font-style: normal; color: #E8C9A0; }
  #shopify-section-{{ section.id }} .eh-hero2__sub { font-family: "Inter", system-ui, sans-serif; font-size: 1.7rem; line-height: 1.55; color: #E8D5BE; margin: 1.6rem 0 0; }
  #shopify-section-{{ section.id }} .eh-hero2__sub p { margin: 0; }
  #shopify-section-{{ section.id }} .eh-hero2__btn {
    align-self: flex-start; margin-top: 2.8rem; background: #FFFCF7; color: #3A2818;
    font-family: "Inter", system-ui, sans-serif; font-weight: 700; font-size: 1.5rem;
    padding: 1.3rem 2.8rem; border-radius: 999px; text-decoration: none; transition: transform .15s ease, filter .15s ease;
  }
  #shopify-section-{{ section.id }} .eh-hero2__btn:hover { transform: translateY(-2px); filter: brightness(0.97); }
  #shopify-section-{{ section.id }} .eh-hero2__media { position: relative; background: #EFE3D2; }
  #shopify-section-{{ section.id }} .eh-hero2__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  #shopify-section-{{ section.id }} .eh-hero2__media-ph { width: 100%; height: 100%; min-height: 42rem; background: radial-gradient(circle at 40% 35%, #B07A45, #4A2C17); }

  #shopify-section-{{ section.id }} .eh-hero2__nav {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 3;
    width: 4rem; height: 4rem; border-radius: 50%; border: none; cursor: pointer;
    background: rgba(255,252,247,0.92); color: #5C3A1E; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 6px 16px rgba(0,0,0,0.18); transition: background .15s ease;
  }
  #shopify-section-{{ section.id }} .eh-hero2__nav:hover { background: #fff; }
  #shopify-section-{{ section.id }} .eh-hero2__nav svg { width: 2rem; height: 2rem; }
  #shopify-section-{{ section.id }} .eh-hero2__nav--prev { left: 1.4rem; }
  #shopify-section-{{ section.id }} .eh-hero2__nav--next { right: 1.4rem; }

  #shopify-section-{{ section.id }} .eh-hero__dots { display: flex; gap: 0.7rem; justify-content: center; margin: 1.6rem 0 0; padding: 0; }
  #shopify-section-{{ section.id }} .eh-hero__dot { width: 1rem; height: 1rem; border-radius: 50%; padding: 0; border: none; cursor: pointer; background: rgba(92,58,30,0.22); transition: background .2s ease, transform .2s ease; }
  #shopify-section-{{ section.id }} .eh-hero__dot.is-active { background: #5C3A1E; transform: scale(1.15); }

  @media screen and (max-width: 860px) {
    #shopify-section-{{ section.id }} .eh-hero2 { padding: 16px 1.4rem 6px; }
    #shopify-section-{{ section.id }} .eh-hero2__in { grid-template-columns: 1fr; min-height: 0; }
    #shopify-section-{{ section.id }} .eh-hero2__media { order: -1; aspect-ratio: 16 / 11; }
    #shopify-section-{{ section.id }} .eh-hero2__media-ph { min-height: 0; aspect-ratio: 16 / 11; }
    #shopify-section-{{ section.id }} .eh-hero2__text { padding: 2.8rem 2rem; }
    #shopify-section-{{ section.id }} .eh-hero2__title { font-size: 3rem; }
    #shopify-section-{{ section.id }} .eh-hero2__sub { font-size: 1.5rem; }
    #shopify-section-{{ section.id }} .eh-hero2__nav { width: 3.4rem; height: 3.4rem; }
  }
  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .eh-hero__slide { transition: none; }
  }
{%- endstyle -%}

<section class="eh-hero2" data-eh-hero data-eh-autoplay="{{ section.settings.autoplay_speed | times: 1000 }}">
  <div class="eh-hero2__frame">
    <div class="eh-hero2__slides">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {% render 'eh-hero-slide', s: block.settings, active: forloop.first, attrs: block.shopify_attributes %}
        {%- endfor -%}
      {%- else -%}
        {% render 'eh-hero-slide', s: section.settings, active: true %}
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button type="button" class="eh-hero2__nav eh-hero2__nav--prev" data-eh-prev aria-label="Önceki">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button type="button" class="eh-hero2__nav eh-hero2__nav--next" data-eh-next aria-label="Sonraki">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <div class="eh-hero__dots" role="tablist" aria-label="Hero slaytları">
      {%- for block in section.blocks -%}
        <button type="button" class="eh-hero__dot{% if forloop.first %} is-active{% endif %}" data-eh-dot="{{ forloop.index0 }}" aria-label="Slayt {{ forloop.index }}" {{ block.shopify_attributes }}></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var root = document.querySelector('#shopify-section-{{ section.id }} [data-eh-hero]');
    if (!root || root.dataset.ehInit) return;
    root.dataset.ehInit = '1';
    var slides = [].slice.call(root.querySelectorAll('.eh-hero__slide'));
    var dots = [].slice.call(root.querySelectorAll('.eh-hero__dot'));
    if (slides.length < 2) return;
    var n = slides.length, i = 0, timer = null;
    var speed = parseInt(root.getAttribute('data-eh-autoplay'), 10) || 6000;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function show(k) {
      i = (k + n) % n;
      slides.forEach(function (sl, idx) { sl.classList.toggle('is-active', idx === i); });
      dots.forEach(function (d, idx) { d.classList.toggle('is-active', idx === i); });
    }
    function next() { show(i + 1); }
    function prev() { show(i - 1); }
    function start() { if (reduce) return; stop(); timer = setInterval(next, speed); }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach(function (d, idx) { d.addEventListener('click', function () { show(idx); start(); }); });
    var pb = root.querySelector('[data-eh-prev]'); if (pb) pb.addEventListener('click', function () { prev(); start(); });
    var nb = root.querySelector('[data-eh-next]'); if (nb) nb.addEventListener('click', function () { next(); start(); });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', function () { document.hidden ? stop() : start(); });

    var x0 = null;
    root.addEventListener('touchstart', function (e) { x0 = e.touches[0].clientX; stop(); }, { passive: true });
    root.addEventListener('touchend', function (e) {
      if (x0 === null) return;
      var dx = e.changedTouches[0].clientX - x0;
      if (Math.abs(dx) > 40) { show(dx < 0 ? i + 1 : i - 1); }
      x0 = null; start();
    }, { passive: true });

    start();
  })();
</script>

{% schema %}
{
  "name": "Muybieno Hero",
  "tag": "section",
  "class": "eh-hero-section",
  "max_blocks": 5,
  "settings": [
    { "type": "paragraph", "content": "Slayt eklemek için aşağıdan 'Slayt' bloğu ekleyin. Her slayt: sol espresso panel (başlık + alt yazı + buton) + sağ görsel." },
    { "type": "range", "id": "autoplay_speed", "min": 3, "max": 12, "step": 1, "unit": "sn", "label": "Otomatik geçiş süresi", "default": 6 },
    { "type": "header", "content": "Tekil içerik (slayt bloğu yoksa kullanılır)" },
    { "type": "text", "id": "badge", "label": "Rozet metni", "default": "Haftalık taze kavrum" },
    { "type": "richtext", "id": "heading", "label": "Başlık", "default": "<p>Her fincanda <em>eşsiz</em> bir lezzet</p>" },
    { "type": "richtext", "id": "text", "label": "Açıklama", "default": "<p>Dünyanın seçkin bölgelerinden, ustalıkla kavrulmuş tek origin çekirdekler.</p>" },
    { "type": "text", "id": "button_label", "label": "Buton metni", "default": "Kahveleri keşfet" },
    { "type": "url", "id": "button_link", "label": "Buton linki" },
    { "type": "image_picker", "id": "image", "label": "Görsel" },
    { "type": "text", "id": "product_label", "label": "Görsel alt metni (erişilebilirlik)" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slayt",
      "settings": [
        { "type": "text", "id": "badge", "label": "Rozet metni" },
        { "type": "richtext", "id": "heading", "label": "Başlık", "info": "<em>...</em> krem renginde vurgu." },
        { "type": "richtext", "id": "text", "label": "Açıklama" },
        { "type": "text", "id": "button_label", "label": "Buton metni" },
        { "type": "url", "id": "button_link", "label": "Buton linki" },
        { "type": "image_picker", "id": "image", "label": "Görsel" },
        { "type": "text", "id": "product_label", "label": "Görsel alt metni (erişilebilirlik)" }
      ]
    }
  ],
  "presets": [ { "name": "Muybieno Hero" } ]
}
{% endschema %}
